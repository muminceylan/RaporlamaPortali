@page "/"

<PageTitle>Ana Sayfa - Raporlama Portali</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
    Hoş Geldiniz
</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudCard Class="mud-height-full" Style="cursor: pointer;" @onclick="@(() => NavigationManager.NavigateTo("/yan-urunler"))">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar Color="Color.Success" Size="Size.Large">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory" />
                    </MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Tüm Ürünler Satış Raporu</MudText>
                    <MudText Typo="Typo.body2">Melas, Küspe, Alkol, Şeker</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2" Class="mb-2">
                    Yan ürün ve şeker satış, üretim ve iade raporları. Melas, yaş/kuru küspe, etil alkol ve şeker takibi.
                </MudText>
                <MudChipSet>
                    <MudChip Color="Color.Success" Size="Size.Small">Aktif</MudChip>
                </MudChipSet>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Text" Color="Color.Primary">Raporlara Git</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudCard Class="mud-height-full" Style="cursor: pointer;" @onclick="@(() => NavigationManager.NavigateTo("/pancar-raporu"))">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar Color="Color.Success" Size="Size.Large">
                        <MudIcon Icon="@Icons.Material.Filled.Agriculture" />
                    </MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Pancar Raporu</MudText>
                    <MudText Typo="Typo.body2">Çiftçi Borç/Alacak, Avans, İcmal</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2" Class="mb-2">
                    Pancar ödemeleri ve çiftçi hesap takibi. Avans, kantar, kesinti ve hakediş raporları.
                </MudText>
                <MudChipSet>
                    <MudChip Color="Color.Success" Size="Size.Small">Aktif</MudChip>
                </MudChipSet>
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Text" Color="Color.Primary">Raporlara Git</MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

<MudDivider Class="my-6" />

<MudGrid>
    <MudItem xs="12">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                Sistem Bilgileri
            </MudText>
            <MudSimpleTable Hover="true">
                <tbody>
                    <tr>
                        <td><strong>Sunucu</strong></td>
                        <td>192.168.0.50\DOGUSLGSRV</td>
                    </tr>
                    <tr>
                        <td><strong>Veritabanı</strong></td>
                        <td>DOGUSNDB</td>
                    </tr>
                    <tr>
                        <td><strong>Firma No</strong></td>
                        <td>211</td>
                    </tr>
                    <tr>
                        <td><strong>Uygulama Versiyonu</strong></td>
                        <td>1.0.0</td>
                    </tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;
}
