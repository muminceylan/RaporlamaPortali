@page "/giris"
@model RaporlamaPortali.Pages.GirisModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Giriş – Raporlama Portali</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 50%, #388E3C 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .kart {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.25);
            padding: 40px 36px 32px;
            width: 100%;
            max-width: 380px;
        }
        .baslik {
            text-align: center;
            margin-bottom: 28px;
        }
        .baslik .ikon {
            width: 56px; height: 56px;
            background: #1B5E20;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 12px;
        }
        .baslik .ikon svg { width: 32px; height: 32px; fill: #fff; }
        .baslik h1 { font-size: 20px; color: #1B5E20; font-weight: 700; }
        .baslik p { font-size: 12px; color: #777; margin-top: 4px; }
        .alan { margin-bottom: 16px; }
        .alan label { display: block; font-size: 13px; color: #444; font-weight: 600; margin-bottom: 6px; }
        .alan input {
            width: 100%; padding: 10px 14px;
            border: 1.5px solid #ccc; border-radius: 7px;
            font-size: 14px; color: #222;
            transition: border-color .2s;
            outline: none;
        }
        .alan input:focus { border-color: #1B5E20; }
        .btn-giris {
            width: 100%; padding: 12px;
            background: #1B5E20; color: #fff;
            border: none; border-radius: 7px;
            font-size: 15px; font-weight: 700;
            cursor: pointer; margin-top: 8px;
            transition: background .2s;
        }
        .btn-giris:hover { background: #2E7D32; }
        .hata {
            background: #FFEBEE; border: 1px solid #EF9A9A;
            color: #C62828; border-radius: 7px;
            padding: 10px 14px; font-size: 13px;
            margin-bottom: 16px; text-align: center;
        }
        .alt { text-align: center; margin-top: 20px; font-size: 11px; color: #aaa; }
    </style>
</head>
<body>
    <div class="kart">
        <div class="baslik">
            <div class="ikon">
                <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/></svg>
            </div>
            <h1>Raporlama Portali</h1>
            <p>Doğuş Çay – Afyon Şeker Fabrikası</p>
        </div>

        @if (Model.Hata)
        {
            <div class="hata">⚠ Kullanıcı adı veya şifre hatalı.</div>
        }

        <form method="post" action="/giris-yap">
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <div class="alan">
                <label for="kullanici">Kullanıcı Adı</label>
                <input type="text" id="kullanici" name="kullanici" autocomplete="username" autofocus />
            </div>
            <div class="alan">
                <label for="sifre">Şifre</label>
                <input type="password" id="sifre" name="sifre" autocomplete="current-password" />
            </div>
            <button type="submit" class="btn-giris">Giriş Yap</button>
        </form>

        <div class="alt">© @DateTime.Now.Year Mümin CEYLAN</div>
    </div>
</body>
</html>
