@page "/pancar-raporu"
@using RaporlamaPortali.Models
@using RaporlamaPortali.Services
@inject PancarRaporService PancarService
@inject HtmlRaporService HtmlService
@inject ZamanliMailService MailService
@inject IServiceProvider Services

<PageTitle>Pancar Raporu</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Agriculture" Class="mr-2" Style="color:#1a237e" />
    Pancar Raporu — Kampanya @PancarRaporService.KampanyaYili()
</MudText>
<MudText Typo="Typo.caption" Class="mb-4" Color="Color.Secondary">
    Afyon Şeker Fabrikası · Veri kaynağı: SabNetPMHS
</MudText>

@if (_yukleniyor)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    <MudText>Veriler yükleniyor...</MudText>
}
else
{
    <!-- ÖZET KARTLAR -->
    <MudGrid Class="mb-4">
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="2" Class="pa-3 text-center">
                <MudText Typo="Typo.h5" Color="Color.Primary">@_ozet.ToplamCiftci.ToString("N0")</MudText>
                <MudText Typo="Typo.caption">Toplam Çiftçi</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="2" Class="pa-3 text-center">
                <MudText Typo="Typo.h5" Color="Color.Success">@((_ozet.ToplamTaahhut/1000).ToString("N0")) ton</MudText>
                <MudText Typo="Typo.caption">Toplam Taahhüt</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="2" Class="pa-3 text-center">
                <MudText Typo="Typo.h5" Color="Color.Warning">@_icmalDetay.NetMiktarTon.ToString("N1") ton</MudText>
                <MudText Typo="Typo.caption">Gelen Net</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="2" Class="pa-3 text-center">
                <MudText Typo="Typo.h5" Color="Color.Error">%@_ozet.OrtFireOrani.ToString("N2")</MudText>
                <MudText Typo="Typo.caption">Fire Oranı</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="2" Class="pa-3 text-center">
                <MudText Typo="Typo.h5" Color="Color.Info">%@_ozet.OrtPolar.ToString("N2")</MudText>
                <MudText Typo="Typo.caption">Polar Oranı</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Elevation="2" Class="pa-3 text-center">
                <MudText Typo="Typo.h5" Style="color:#B71C1C">@_mustahsilBorcAlacak.ToString("N0") ₺</MudText>
                <MudText Typo="Typo.caption">@(_mustahsilBorcAlacak > 0 ? "Müstahsil Borçlu" : "Müstahsil Alacaklı")</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid>
        <!-- SOL: AVANS TABLOSU -->
        <MudItem xs="12" md="6">
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Class="mr-1" />
                            İCMAL
                        </MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="YenileAsync" Title="Yenile" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <table style="width:100%;border-collapse:collapse;font-size:0.88em;">
                        <tr style="background:#C62828;color:white;font-weight:bold;">
                            <td style="padding:9px 14px;">AVANS ADI</td>
                            <td style="padding:9px 14px;text-align:right;">TUTAR (₺)</td>
                        </tr>

                        <!-- NAKDİ -->
                        @foreach (var r in _nakdiRows)
                        {
                            <tr style="border-bottom:1px solid #f0f0f0;">
                                <td style="padding:5px 14px;">@r.Ad</td>
                                <td style="padding:5px 14px;text-align:right;">@r.Tutar.ToString("N2")</td>
                            </tr>
                        }
                        <tr style="background:#FDD835;font-weight:bold;">
                            <td style="padding:7px 14px;">NAKDİ AVANS TOPLAMI</td>
                            <td style="padding:7px 14px;text-align:right;">@_nakdiToplam.ToString("N2")</td>
                        </tr>

                        <!-- AYNİ -->
                        @foreach (var r in _ayniRows)
                        {
                            <tr style="border-bottom:1px solid #f0f0f0;">
                                <td style="padding:5px 14px;">@r.Ad</td>
                                <td style="padding:5px 14px;text-align:right;">@r.Tutar.ToString("N2")</td>
                            </tr>
                        }
                        <tr style="background:#388E3C;color:white;font-weight:bold;">
                            <td style="padding:7px 14px;">AYNİ AVANS TOPLAMI</td>
                            <td style="padding:7px 14px;text-align:right;">@_ayniToplam.ToString("N2")</td>
                        </tr>

                        <!-- PANCAR BEDELİ ÖDEMESİ -->
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 14px;">PANCAR BEDELİ ÖDEMESİ</td>
                            <td style="padding:5px 14px;text-align:right;">0,00</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 14px;">Ödenen Kota Fazlası Bedeli</td>
                            <td style="padding:5px 14px;text-align:right;">@_finans.KotaFazlasi.ToString("N2")</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 14px;">Ödenen C Pancar Bedeli</td>
                            <td style="padding:5px 14px;text-align:right;">@_finans.CPancari.ToString("N2")</td>
                        </tr>
                        <tr style="background:#E53935;color:white;font-weight:bold;">
                            <td style="padding:7px 14px;">PANCAR BEDELİ ÖDEMESİ</td>
                            <td style="padding:7px 14px;text-align:right;">@_pancarBedeliToplam.ToString("N2")</td>
                        </tr>

                        <!-- AVANS TOPLAMI -->
                        <tr style="background:#B71C1C;color:white;font-weight:bold;font-size:1.05em;">
                            <td style="padding:9px 14px;">AVANS TOPLAMI</td>
                            <td style="padding:9px 14px;text-align:right;">@_avansToplami.ToString("N2")</td>
                        </tr>

                        <!-- FİNANSAL -->
                        <tr style="border-bottom:1px solid #f0f0f0;background:#fffde7;">
                            <td style="padding:5px 14px;">AVANS KDV Sİ</td>
                            <td style="padding:5px 14px;text-align:right;">@_finans.AvansKdv.ToString("N2")</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 14px;">STOPAJ</td>
                            <td style="padding:5px 14px;text-align:right;">@_finans.AlimStopaji.ToString("N2")</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 14px;">Ödenen Nakliye Primi</td>
                            <td style="padding:5px 14px;text-align:right;">@_finans.NakliyePrimi.ToString("N2")</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 14px;">Kota Cezası</td>
                            <td style="padding:5px 14px;text-align:right;">0,00</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 14px;">Ödenen Bağkur Primi</td>
                            <td style="padding:5px 14px;text-align:right;">@_finans.BagkurBorcu.ToString("N2")</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 14px;">Borsa Tescil</td>
                            <td style="padding:5px 14px;text-align:right;">@_finans.BorsaTescil.ToString("N2")</td>
                        </tr>

                        <!-- TOPLAM MÜSTAHSİL BORCU -->
                        <tr style="background:#B71C1C;color:white;font-weight:bold;font-size:1.08em;">
                            <td style="padding:9px 14px;">TOPLAM MÜSTAHSİL BORCU</td>
                            <td style="padding:9px 14px;text-align:right;">@_genelToplam.ToString("N2")</td>
                        </tr>

                        <!-- SEPARATOR -->
                        <tr style="background:#e8eaf6;">
                            <td colspan="2" style="padding:4px 14px;font-size:0.8em;color:#666;">▼ Hakediş Özeti</td>
                        </tr>

                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 14px;">PANCAR BEDELİ</td>
                            <td style="padding:5px 14px;text-align:right;">@_icmalDetay.PancarBedeliToplam.ToString("N2")</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 14px;">MÜSTAHSİL NAKLİYE</td>
                            <td style="padding:5px 14px;text-align:right;">@_icmalDetay.MustahsilNakliye.ToString("N2")</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 14px;">KÜSPE PRİMİ</td>
                            <td style="padding:5px 14px;text-align:right;">@_icmalDetay.KuspePrimi.ToString("N2")</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 14px;">KOTA TAMAMLAMA PRİMİ</td>
                            <td style="padding:5px 14px;text-align:right;">@_icmalDetay.KotaTamamlamaPrimi.ToString("N2")</td>
                        </tr>
                        <tr style="background:#1565C0;color:white;font-weight:bold;">
                            <td style="padding:7px 14px;">MÜSTAHSİL HAKEDİŞ TOPLAMI</td>
                            <td style="padding:7px 14px;text-align:right;">@_icmalDetay.HakedisToplamı.ToString("N2")</td>
                        </tr>
                        <tr style="background:@(_mustahsilBorcAlacak > 0 ? "#B71C1C" : "#1B5E20");color:white;font-weight:bold;font-size:1.05em;">
                            <td style="padding:9px 14px;">@(_mustahsilBorcAlacak > 0 ? "MÜSTAHSİL BORÇLU" : "MÜSTAHSİL ALACAKLI")</td>
                            <td style="padding:9px 14px;text-align:right;">@Math.Abs(_mustahsilBorcAlacak).ToString("N2")</td>
                        </tr>
                    </table>
                </MudCardContent>
                <MudCardActions>
                    <MudButton StartIcon="@Icons.Material.Filled.Email"
                               Color="Color.Primary" Variant="Variant.Filled"
                               OnClick="MailGonderAsync" Disabled="_mailGonderiliyor">
                        @(_mailGonderiliyor ? "Gönderiliyor..." : "Mail Gönder")
                    </MudButton>
                    @if (_mailSonucu != null)
                    {
                        <MudAlert Severity="@(_mailBasarili ? Severity.Success : Severity.Error)"
                                  Dense="true" Class="ml-2">
                            @_mailSonucu
                        </MudAlert>
                    }
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- SAĞ: GENEL İCMAL + NAKLİYE/MOUSE/KEPÇE + PANCAR TÜRLERİ -->
        <MudItem xs="12" md="6">

            <!-- GENEL İCMAL -->
            <MudCard Elevation="3" Class="mb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.BarChart" Class="mr-1" />
                            Genel İcmal
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <table style="width:100%;border-collapse:collapse;font-size:0.88em;">
                        <tr style="background:#283593;color:white;font-weight:bold;">
                            <td style="padding:8px 12px;">AÇIKLAMA</td>
                            <td style="padding:8px 12px;text-align:right;">MİKTAR (TON)</td>
                            <td style="padding:8px 12px;text-align:right;">TUTAR (₺)</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 12px;">Pancar Bedeli</td>
                            <td style="padding:5px 12px;text-align:right;">@_icmalDetay.NetMiktarTon.ToString("N3")</td>
                            <td style="padding:5px 12px;text-align:right;">@_icmalDetay.PancarBedeliToplam.ToString("N2")</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 12px;">Müstahsil Nakliye</td>
                            <td style="padding:5px 12px;text-align:right;">—</td>
                            <td style="padding:5px 12px;text-align:right;">@_icmalDetay.MustahsilNakliye.ToString("N2")</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 12px;">Küspe Primi</td>
                            <td style="padding:5px 12px;text-align:right;">—</td>
                            <td style="padding:5px 12px;text-align:right;">@_icmalDetay.KuspePrimi.ToString("N2")</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 12px;">Kota Tamamlama Primi</td>
                            <td style="padding:5px 12px;text-align:right;">—</td>
                            <td style="padding:5px 12px;text-align:right;">@_icmalDetay.KotaTamamlamaPrimi.ToString("N2")</td>
                        </tr>
                        <tr style="background:#e8eaf6;font-weight:bold;">
                            <td style="padding:6px 12px;">Toplam Maliyet</td>
                            <td style="padding:6px 12px;text-align:right;">—</td>
                            <td style="padding:6px 12px;text-align:right;">@_icmalDetay.HakedisToplamı.ToString("N2")</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 12px;">Müstahsile Ödenen</td>
                            <td style="padding:5px 12px;text-align:right;">—</td>
                            <td style="padding:5px 12px;text-align:right;">@_genelToplam.ToString("N2")</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 12px;">Müstahsil Hakedişi</td>
                            <td style="padding:5px 12px;text-align:right;">—</td>
                            <td style="padding:5px 12px;text-align:right;">@_icmalDetay.HakedisToplamı.ToString("N2")</td>
                        </tr>
                        <tr style="background:@(_mustahsilBorcAlacak > 0 ? "#B71C1C" : "#1B5E20");color:white;font-weight:bold;">
                            <td style="padding:7px 12px;">@(_mustahsilBorcAlacak > 0 ? "Müstahsil Borçlu" : "Müstahsil Alacaklı")</td>
                            <td style="padding:7px 12px;text-align:right;">—</td>
                            <td style="padding:7px 12px;text-align:right;">@Math.Abs(_mustahsilBorcAlacak).ToString("N2")</td>
                        </tr>
                    </table>
                </MudCardContent>
            </MudCard>

            <!-- PANCAR TÜRLERİ -->
            <MudCard Elevation="3" Class="mb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Grass" Class="mr-1" />
                            Pancar Türleri
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <table style="width:100%;border-collapse:collapse;font-size:0.88em;">
                        <tr style="background:#2E7D32;color:white;font-weight:bold;">
                            <td style="padding:8px 12px;">PANCAR TÜRÜ</td>
                            <td style="padding:8px 12px;text-align:right;">MİKTAR (TON)</td>
                            <td style="padding:8px 12px;text-align:right;">TUTAR (₺)</td>
                            <td style="padding:8px 12px;text-align:right;">BİRİM FİYAT</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 12px;">A Pancarı</td>
                            <td style="padding:5px 12px;text-align:right;">@_icmalDetay.APancariTon.ToString("N3")</td>
                            <td style="padding:5px 12px;text-align:right;">@_icmalDetay.APancariBedeli.ToString("N2")</td>
                            <td style="padding:5px 12px;text-align:right;">@_icmalDetay.ABirimFiyati.ToString("N4")</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 12px;">C Pancarı</td>
                            <td style="padding:5px 12px;text-align:right;">@_icmalDetay.CPancariTon.ToString("N3")</td>
                            <td style="padding:5px 12px;text-align:right;">@_icmalDetay.CPancariBedeli.ToString("N2")</td>
                            <td style="padding:5px 12px;text-align:right;">@_icmalDetay.CBirimFiyati.ToString("N4")</td>
                        </tr>
                        <tr style="border-bottom:1px solid #f0f0f0;">
                            <td style="padding:5px 12px;">Kota Fazlası</td>
                            <td style="padding:5px 12px;text-align:right;">@_icmalDetay.KotaFazlasiTon.ToString("N3")</td>
                            <td style="padding:5px 12px;text-align:right;">@_icmalDetay.KotaFazlasiBedeli.ToString("N2")</td>
                            <td style="padding:5px 12px;text-align:right;">@_icmalDetay.KFBirimFiyati.ToString("N4")</td>
                        </tr>
                        <tr style="background:#1B5E20;color:white;font-weight:bold;">
                            <td style="padding:7px 12px;">TOPLAM</td>
                            <td style="padding:7px 12px;text-align:right;">@((_icmalDetay.APancariTon + _icmalDetay.CPancariTon + _icmalDetay.KotaFazlasiTon).ToString("N3"))</td>
                            <td style="padding:7px 12px;text-align:right;">@_icmalDetay.PancarBedeliToplam.ToString("N2")</td>
                            <td style="padding:7px 12px;text-align:right;">—</td>
                        </tr>
                    </table>
                </MudCardContent>
            </MudCard>

            <!-- NAKLİYE / MOUSE / KEPÇE -->
            <MudCard Elevation="3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Class="mr-1" />
                            Nakliye / Mouse / Kepçe Bilgileri
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <table style="width:100%;border-collapse:collapse;font-size:0.88em;">
                        <tr style="background:#4527A0;color:white;font-weight:bold;">
                            <td style="padding:8px 12px;">TİP / AÇIKLAMA</td>
                            <td style="padding:8px 12px;text-align:right;">NET (kg)</td>
                            <td style="padding:8px 12px;text-align:right;">TUTAR (₺)</td>
                            <td style="padding:8px 12px;text-align:right;">ORT. (₺/ton)</td>
                        </tr>
                        @foreach (var grup in _nakliyeGruplari)
                        {
                            <tr style="background:#ede7f6;font-weight:bold;">
                                <td colspan="4" style="padding:5px 12px;">@grup.Key</td>
                            </tr>
                            @foreach (var k in grup.Value)
                            {
                                <tr style="border-bottom:1px solid #f0f0f0;">
                                    <td style="padding:4px 12px 4px 20px;">@k.Aciklama</td>
                                    <td style="padding:4px 12px;text-align:right;">@k.Net.ToString("N0")</td>
                                    <td style="padding:4px 12px;text-align:right;">@k.Tutar.ToString("N2")</td>
                                    <td style="padding:4px 12px;text-align:right;">@(k.Net > 0 ? (k.Tutar / k.Net * 1000).ToString("N2") : "—")</td>
                                </tr>
                            }
                        }
                        @if (!_nakliyeGruplari.Any())
                        {
                            <tr><td colspan="4" style="padding:10px;text-align:center;color:#888;">Henüz veri yok</td></tr>
                        }
                    </table>
                </MudCardContent>
            </MudCard>

        </MudItem>
    </MudGrid>
}

@code {
    private bool    _yukleniyor       = true;
    private bool    _mailGonderiliyor = false;
    private bool    _mailBasarili     = false;
    private string? _mailSonucu       = null;

    private List<PancarAvansKayit> _avans       = new();
    private PancarFinansOzet       _finans      = new();
    private PancarOzetIstatistik   _ozet        = new();
    private PancarIcmalDetay       _icmalDetay  = new();
    private List<PancarIcmalKayit> _icmal       = new();

    private record AvansRow(string Ad, decimal Tutar);
    private List<AvansRow> _nakdiRows = new();
    private List<AvansRow> _ayniRows  = new();

    private decimal _nakdiToplam;
    private decimal _ayniToplam;
    private decimal _pancarBedeliToplam;
    private decimal _avansToplami;
    private decimal _genelToplam;
    private decimal _mustahsilBorcAlacak;

    private Dictionary<string, List<PancarIcmalKayit>> _nakliyeGruplari = new();

    private static readonly (string Grup, string Ad)[] NakdiSira = {
        ("Pancar Avansı","Pancar Avansı"), ("Hasat Makinesi Avansı","Hasat Makinesi Avansı"),
        ("1. Avans","1. Avans"), ("2. Avans","2. Avans"), ("3. Avans","3. Avans"),
        ("4. Avans","4. Avans"), ("5. Avans","5. Avans"), ("6. Avans","6. Avans"),
        ("Küspe","Küspe Avansı"), ("Söküm Avansı","Söküm Avansı"),
    };

    private static readonly (string Grup, string Ad)[] AyniSira = {
        ("Gübre","Gübre Avansı"), ("İlaç","İlaç Avansı"), ("Tohum","Tohum Avansı"),
        ("Çay","Çay Avansı"), ("Şeker","Şeker Avansı"), ("Küspe","Küspe Avansı"),
        ("Fatura Edilen Söküm Avansı","Fatura Edilen Söküm Avansı"), ("Söküm Avansı","Söküm Avansı"),
    };

    protected override async Task OnInitializedAsync() => await YenileAsync();

    private async Task YenileAsync()
    {
        _yukleniyor = true;
        StateHasChanged();

        var t1 = PancarService.GetOzetIstatistikAsync();
        var t2 = PancarService.GetAvansAsync();
        var t3 = PancarService.GetFinansOzetAsync();
        var t4 = PancarService.GetIcmalDetayAsync();
        var t5 = PancarService.GetIcmalAsync();
        await Task.WhenAll(t1, t2, t3, t4, t5);
        _ozet       = t1.Result;
        _avans      = t2.Result;
        _finans     = t3.Result;
        _icmalDetay = t4.Result;
        _icmal      = t5.Result;

        Hesapla();
        _yukleniyor = false;
    }

    private void Hesapla()
    {
        var nakdiDict = _avans.Where(x => x.KaynakEvrak.Contains("NAKD"))
                              .ToDictionary(x => x.AvansGrubu.Trim(), x => x.TutarToplami);
        var ayniDict  = _avans.Where(x => x.KaynakEvrak.Contains("AYN"))
                              .ToDictionary(x => x.AvansGrubu.Trim(), x => x.TutarToplami);

        decimal Get(Dictionary<string, decimal> d, string k) =>
            d.TryGetValue(k, out var v) ? v : 0m;

        _nakdiRows = new();
        var nakdiEk = new HashSet<string>();
        foreach (var (grup, ad) in NakdiSira)
        {
            _nakdiRows.Add(new AvansRow(ad, Get(nakdiDict, grup)));
            nakdiEk.Add(grup);
        }
        foreach (var kv in nakdiDict.Where(kv => !nakdiEk.Contains(kv.Key)))
            _nakdiRows.Add(new AvansRow(kv.Key, kv.Value));

        _ayniRows = new();
        var ayniEk = new HashSet<string>();
        foreach (var (grup, ad) in AyniSira)
        {
            _ayniRows.Add(new AvansRow(ad, Get(ayniDict, grup)));
            ayniEk.Add(grup);
        }
        foreach (var kv in ayniDict.Where(kv => !ayniEk.Contains(kv.Key)))
            _ayniRows.Add(new AvansRow(kv.Key, kv.Value));

        _nakdiToplam        = nakdiDict.Values.Sum();
        _ayniToplam         = ayniDict.Values.Sum();
        _pancarBedeliToplam = _finans.KotaFazlasi + _finans.CPancari;
        _avansToplami       = _nakdiToplam + _ayniToplam + _pancarBedeliToplam;
        _genelToplam        = _avansToplami + _finans.AvansKdv + _finans.AlimStopaji
                              + _finans.NakliyePrimi + _finans.BagkurBorcu + _finans.BorsaTescil;

        // Müstahsile Ödenen - Hakediş = Borç(+) / Alacak(-)
        _mustahsilBorcAlacak = _genelToplam - _icmalDetay.HakedisToplamı;

        // Nakliye/Mouse/Kepçe grupları
        _nakliyeGruplari = _icmal
            .GroupBy(k => k.Tip)
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    private async Task MailGonderAsync()
    {
        _mailGonderiliyor = true;
        _mailSonucu = null;
        StateHasChanged();

        try
        {
            using var scope = Services.CreateScope();
            var sonuc = await MailService.PancarRaporManuelGonder(scope.ServiceProvider);
            _mailBasarili = sonuc;
            _mailSonucu   = sonuc ? "Mail başarıyla gönderildi!" : "Mail gönderilemedi.";
        }
        catch (Exception ex)
        {
            _mailBasarili = false;
            _mailSonucu   = "Hata: " + ex.Message;
        }

        _mailGonderiliyor = false;
        await Task.Delay(5000);
        _mailSonucu = null;
    }
}
