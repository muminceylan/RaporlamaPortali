@page "/seker-dairesi"
@inject SekerDairesiService SekerDairesiService
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>Şeker Dairesi Raporu</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Inventory" Class="mr-2" />
    Türk Şekersiz ÜSS Raporu
</MudText>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" Class="mb-4">

    @* ══════════════════════════════════════════════════════════════════
       TAB 1 – SADE ŞEKER ANALİZİ  (VBA CommandButton1 / Module3)
       ══════════════════════════════════════════════════════════════════ *@
    <MudTabPanel Text="Sade Şeker Analizi" Icon="@Icons.Material.Filled.Analytics">

        <MudPaper Class="pa-4 mb-4">
            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker Label="Başlangıç Tarihi" @bind-Date="_analizBaslangic"
                                   DateFormat="dd.MM.yyyy" Editable="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudDatePicker Label="Bitiş Tarihi" @bind-Date="_analizBitis"
                                   DateFormat="dd.MM.yyyy" Editable="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="6">
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-1">
                        Dönem başı stoklar 01.09.2025 kampanya başı değerlerinden otomatik hesaplanır.
                        Farklı bir başlangıç tarihi seçildiğinde önceki dönem sonucu kullanılır.
                    </MudAlert>
                </MudItem>
                <MudItem xs="12" Class="d-flex gap-2 align-center flex-wrap">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="AnalizYap" Disabled="@_analizYukleniyor">
                        @if (_analizYukleniyor)
                        {
                            <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                        }
                        <MudIcon Icon="@Icons.Material.Filled.BarChart" Class="mr-1" />
                        Analiz Yap
                    </MudButton>
                    <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                        <MudButton OnClick="@(() => SetAnalizAraligi(0))">Bu Ay</MudButton>
                        <MudButton OnClick="@(() => SetAnalizAraligi(1))">Bu Yıl</MudButton>
                        <MudButton OnClick="@(() => SetAnalizAraligi(2))">Geçen Ay</MudButton>
                    </MudButtonGroup>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @if (_analizHata != null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_analizHata</MudAlert>
        }

        @if (_analizSonuc != null)
        {
            @* ── Şeker Kategorisi Bazlı Analiz ── *@
            <MudPaper Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3" Style="color:#1B5E20;">
                    <MudIcon Icon="@Icons.Material.Filled.TableChart" Class="mr-2" />
                    Şeker Kategorisi Bazlı Analiz
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="ml-2">
                        @_analizBaslangic?.ToString("dd.MM.yyyy") – @_analizBitis?.ToString("dd.MM.yyyy")
                    </MudChip>
                </MudText>

                <div style="overflow-x:auto;">
                <MudSimpleTable Hover="true" Dense="true" Bordered="true" Style="font-size:0.78rem; min-width:1200px;">
                    <thead>
                        <tr style="background-color:#2e7d32; color:white;">
                            <th style="padding:8px 6px; border:1px solid #1B5E20; white-space:nowrap;">KATEGORİ</th>
                            <th style="padding:8px 6px; border:1px solid #1B5E20; text-align:right;" title="Dönem başı kullanıcı girişi">Dönem Başı (Kg)</th>
                            <th style="padding:8px 6px; border:1px solid #1B5E20; text-align:right; background-color:#1565C0;">Üretim (Kg)</th>
                            <th style="padding:8px 6px; border:1px solid #1B5E20; text-align:right; background-color:#1565C0;">Satın Alma (Kg)</th>
                            <th style="padding:8px 6px; border:1px solid #1B5E20; text-align:right; background-color:#1565C0;">Satış İade (Kg)</th>
                            <th style="padding:8px 6px; border:1px solid #1B5E20; text-align:right; background-color:#1565C0;">Diğer Giriş (Kg)</th>
                            <th style="padding:8px 6px; border:1px solid #1B5E20; text-align:right; font-weight:700; background-color:#0D47A1;">Top. Giriş (Kg)</th>
                            <th style="padding:8px 6px; border:1px solid #1B5E20; text-align:right; background-color:#b71c1c;">Satış (Kg)</th>
                            <th style="padding:8px 6px; border:1px solid #1B5E20; text-align:right; background-color:#880E4F;">Satış Tutarı (₺)</th>
                            <th style="padding:8px 6px; border:1px solid #1B5E20; text-align:right; background-color:#880E4F;">Ort. Satış Fiyatı (₺/Kg)</th>
                            <th style="padding:8px 6px; border:1px solid #1B5E20; text-align:right; background-color:#b71c1c;">Sarf (Kg)</th>
                            <th style="padding:8px 6px; border:1px solid #1B5E20; text-align:right; background-color:#b71c1c;">Fire (Kg)</th>
                            <th style="padding:8px 6px; border:1px solid #1B5E20; text-align:right; background-color:#b71c1c;">Yemekhane (Kg)</th>
                            <th style="padding:8px 6px; border:1px solid #1B5E20; text-align:right; background-color:#b71c1c;">PROMS (Kg)</th>
                            <th style="padding:8px 6px; border:1px solid #1B5E20; text-align:right; background-color:#b71c1c;">Diğer Çıkış (Kg)</th>
                            <th style="padding:8px 6px; border:1px solid #1B5E20; text-align:right; font-weight:700; background-color:#7B1FA2;">Top. Çıkış (Kg)</th>
                            <th style="padding:8px 6px; border:1px solid #1B5E20; text-align:right; font-weight:700; background-color:#E65100;">Dönem Sonu (Kg)</th>
                            <th style="padding:8px 6px; border:1px solid #1B5E20; text-align:right; font-weight:700; background-color:#E65100;">Dönem Sonu (Ton)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int satirNo = 0; }
                        @foreach (var kat in _analizSonuc)
                        {
                            var bg = satirNo++ % 2 == 0 ? "#fff" : "#f5f5f5";
                            var stokRenk = kat.DonemSonuMiktar < 0 ? "color:#c62828;font-weight:600;" : "";
                            <tr style="background-color:@bg;">
                                <td style="padding:6px;border:1px solid #e0e0e0;font-weight:600;white-space:nowrap;">@kat.KategoriAdi</td>
                                <td style="padding:6px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;">@kat.DonemBasiMiktar.ToString("N0")</td>
                                <td style="padding:6px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;">@kat.UretimMiktar.ToString("N0")</td>
                                <td style="padding:6px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;">@kat.SatinAlmaMiktar.ToString("N0")</td>
                                <td style="padding:6px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;">@kat.SatisIadeMiktar.ToString("N0")</td>
                                <td style="padding:6px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;">@((kat.ReceteFarkMiktar + kat.SayimFazlasiMiktar).ToString("N0"))</td>
                                <td style="padding:6px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;font-weight:700;color:#0D47A1;">@kat.ToplamGirisMiktar.ToString("N0")</td>
                                <td style="padding:6px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;">@kat.SatisMiktar.ToString("N0")</td>
                                <td style="padding:6px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;">@kat.SatisTutar.ToString("N2")</td>
                                <td style="padding:6px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;">@(kat.SatisMiktar > 0 ? (kat.SatisTutar / kat.SatisMiktar).ToString("N2") : "-")</td>
                                <td style="padding:6px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;">@kat.SarfMiktar.ToString("N0")</td>
                                <td style="padding:6px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;">@kat.FireMiktar.ToString("N0")</td>
                                <td style="padding:6px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;">@kat.YemekhaneMiktar.ToString("N0")</td>
                                <td style="padding:6px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;">@kat.PromsMiktar.ToString("N0")</td>
                                <td style="padding:6px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;">@(kat.SatinAlmaIadeMiktar.ToString("N0"))</td>
                                <td style="padding:6px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;font-weight:700;color:#7B1FA2;">@kat.ToplamCikisMiktar.ToString("N0")</td>
                                <td style="padding:6px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;@stokRenk">@kat.DonemSonuMiktar.ToString("N0")</td>
                                <td style="padding:6px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;@stokRenk">@((kat.DonemSonuMiktar / 1000m).ToString("N3"))</td>
                            </tr>
                        }
                        @* TOPLAM satırı *@
                        <tr style="background-color:#FFF9C4;font-weight:700;">
                            <td style="padding:8px 6px;border:1px solid #F9A825;">TOPLAM</td>
                            <td style="padding:8px 6px;border:1px solid #F9A825;text-align:right;font-family:Consolas,monospace;color:#1B5E20;">@(_analizSonuc.Sum(x=>x.DonemBasiMiktar).ToString("N0"))</td>
                            <td style="padding:8px 6px;border:1px solid #F9A825;text-align:right;font-family:Consolas,monospace;color:#1B5E20;">@(_analizSonuc.Sum(x=>x.UretimMiktar).ToString("N0"))</td>
                            <td style="padding:8px 6px;border:1px solid #F9A825;text-align:right;font-family:Consolas,monospace;color:#1B5E20;">@(_analizSonuc.Sum(x=>x.SatinAlmaMiktar).ToString("N0"))</td>
                            <td style="padding:8px 6px;border:1px solid #F9A825;text-align:right;font-family:Consolas,monospace;color:#1B5E20;">@(_analizSonuc.Sum(x=>x.SatisIadeMiktar).ToString("N0"))</td>
                            <td style="padding:8px 6px;border:1px solid #F9A825;text-align:right;font-family:Consolas,monospace;color:#1B5E20;">@(_analizSonuc.Sum(x=>x.ReceteFarkMiktar+x.SayimFazlasiMiktar).ToString("N0"))</td>
                            <td style="padding:8px 6px;border:1px solid #F9A825;text-align:right;font-family:Consolas,monospace;color:#0D47A1;">@(_analizSonuc.Sum(x=>x.ToplamGirisMiktar).ToString("N0"))</td>
                            <td style="padding:8px 6px;border:1px solid #F9A825;text-align:right;font-family:Consolas,monospace;color:#b71c1c;">@(_analizSonuc.Sum(x=>x.SatisMiktar).ToString("N0"))</td>
                            <td style="padding:8px 6px;border:1px solid #F9A825;text-align:right;font-family:Consolas,monospace;color:#880E4F;">@(_analizSonuc.Sum(x=>x.SatisTutar).ToString("N2"))</td>
                            <td style="padding:8px 6px;border:1px solid #F9A825;text-align:right;font-family:Consolas,monospace;color:#880E4F;">@(_analizSonuc.Sum(x=>x.SatisMiktar) > 0 ? (_analizSonuc.Sum(x=>x.SatisTutar) / _analizSonuc.Sum(x=>x.SatisMiktar)).ToString("N2") : "-")</td>
                            <td style="padding:8px 6px;border:1px solid #F9A825;text-align:right;font-family:Consolas,monospace;color:#b71c1c;">@(_analizSonuc.Sum(x=>x.SarfMiktar).ToString("N0"))</td>
                            <td style="padding:8px 6px;border:1px solid #F9A825;text-align:right;font-family:Consolas,monospace;color:#b71c1c;">@(_analizSonuc.Sum(x=>x.FireMiktar).ToString("N0"))</td>
                            <td style="padding:8px 6px;border:1px solid #F9A825;text-align:right;font-family:Consolas,monospace;color:#b71c1c;">@(_analizSonuc.Sum(x=>x.YemekhaneMiktar).ToString("N0"))</td>
                            <td style="padding:8px 6px;border:1px solid #F9A825;text-align:right;font-family:Consolas,monospace;color:#b71c1c;">@(_analizSonuc.Sum(x=>x.PromsMiktar).ToString("N0"))</td>
                            <td style="padding:8px 6px;border:1px solid #F9A825;text-align:right;font-family:Consolas,monospace;color:#b71c1c;">@(_analizSonuc.Sum(x=>x.SatinAlmaIadeMiktar).ToString("N0"))</td>
                            <td style="padding:8px 6px;border:1px solid #F9A825;text-align:right;font-family:Consolas,monospace;color:#7B1FA2;">@(_analizSonuc.Sum(x=>x.ToplamCikisMiktar).ToString("N0"))</td>
                            <td style="padding:8px 6px;border:1px solid #F9A825;text-align:right;font-family:Consolas,monospace;color:#E65100;">@(_analizSonuc.Sum(x=>x.DonemSonuMiktar).ToString("N0"))</td>
                            <td style="padding:8px 6px;border:1px solid #F9A825;text-align:right;font-family:Consolas,monospace;color:#E65100;">@((_analizSonuc.Sum(x=>x.DonemSonuMiktar)/1000m).ToString("N3"))</td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
                </div>
            </MudPaper>

            @* ── Şeker Dairesi Başkanlığı – Hammadde ve Ürünler Üretim Satış ve Stok Bilgileri ── *@
            <MudPaper Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3" Style="color:#1A237E;">
                    <MudIcon Icon="@Icons.Material.Filled.Business" Class="mr-2" />
                    Hammadde ve Ürünler – Üretim, Satış ve Stok Bilgileri
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Class="ml-2">
                        @_analizBaslangic?.ToString("dd.MM.yyyy") – @_analizBitis?.ToString("dd.MM.yyyy")
                    </MudChip>
                </MudText>

                <div style="overflow-x:auto;">
                <table style="width:100%; border-collapse:collapse; font-size:0.78rem; min-width:650px;">
                    <thead>
                        <tr style="background-color:#1A237E; color:white;">
                            <th style="padding:8px 6px; border:1px solid #0D1257; text-align:left; min-width:330px;">HAMMADDE VE ÜRÜNLER</th>
                            <th style="padding:8px 6px; border:1px solid #0D1257; text-align:right; min-width:150px;">Kristal Şeker (Kg)</th>
                            <th style="padding:8px 6px; border:1px solid #0D1257; text-align:right; min-width:150px;">Küp / Paket Şeker (Kg)</th>
                            <th style="padding:8px 6px; border:1px solid #0D1257; text-align:right; min-width:150px;">Toplam</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in HesaplaBaskanlikTablosu())
                        {
                            if (row.Tip == BRowTip.GrupBaslik)
                            {
                                <tr style="background-color:#283593; color:white; font-weight:700;">
                                    <td colspan="4" style="padding:7px 8px; border:1px solid #1A237E; letter-spacing:0.5px; font-size:0.80rem;">@row.Ad</td>
                                </tr>
                            }
                            else if (row.Tip == BRowTip.ToplamSatir)
                            {
                                var totT = row.K + row.P;
                                <tr style="background-color:#FFF9C4; font-weight:700; font-size:0.80rem;">
                                    <td style="padding:6px 8px; border:1px solid #F9A825; padding-left:12px;">@row.Ad</td>
                                    <td style="padding:6px; border:1px solid #F9A825; text-align:right; font-family:Consolas,monospace; color:#1565C0;">@row.K.ToString("N2")</td>
                                    <td style="padding:6px; border:1px solid #F9A825; text-align:right; font-family:Consolas,monospace; color:#1565C0;">@row.P.ToString("N2")</td>
                                    <td style="padding:6px; border:1px solid #F9A825; text-align:right; font-family:Consolas,monospace; color:#E65100; font-weight:800;">@totT.ToString("N2")</td>
                                </tr>
                            }
                            else if (row.Tip == BRowTip.TutarSatir)
                            {
                                var totTl = row.K + row.P;
                                <tr style="background-color:#FCE4EC;">
                                    <td style="padding:6px 8px; border:1px solid #F48FB1; padding-left:20px; font-style:italic;">@row.Ad</td>
                                    <td style="padding:6px; border:1px solid #F48FB1; text-align:right; font-family:Consolas,monospace;">@row.K.ToString("N2")</td>
                                    <td style="padding:6px; border:1px solid #F48FB1; text-align:right; font-family:Consolas,monospace;">@row.P.ToString("N2")</td>
                                    <td style="padding:6px; border:1px solid #F48FB1; text-align:right; font-family:Consolas,monospace; font-weight:700; color:#880E4F;">@totTl.ToString("N2")</td>
                                </tr>
                            }
                            else if (row.Tip == BRowTip.FiyatSatir)
                            {
                                var totF = row.TotOverride ?? row.K;
                                <tr style="background-color:#FFF8E1; font-style:italic;">
                                    <td style="padding:6px 8px; border:1px solid #FFE082; padding-left:20px;">@row.Ad</td>
                                    <td style="padding:6px; border:1px solid #FFE082; text-align:right; font-family:Consolas,monospace; color:#E65100;">@row.K.ToString("N4")</td>
                                    <td style="padding:6px; border:1px solid #FFE082; text-align:right; font-family:Consolas,monospace; color:#E65100;">@(row.P > 0 ? row.P.ToString("N4") : "0,0000")</td>
                                    <td style="padding:6px; border:1px solid #FFE082; text-align:right; font-family:Consolas,monospace; color:#E65100; font-weight:700;">@(totF > 0 ? totF.ToString("N4") : "0,0000")</td>
                                </tr>
                            }
                            else
                            {
                                var totV = row.K + row.P;
                                <tr style="background-color:#fff;">
                                    <td style="padding:5px 8px; border:1px solid #e0e0e0; padding-left:20px;">@row.Ad</td>
                                    <td style="padding:5px; border:1px solid #e0e0e0; text-align:right; font-family:Consolas,monospace;">@row.K.ToString("N2")</td>
                                    <td style="padding:5px; border:1px solid #e0e0e0; text-align:right; font-family:Consolas,monospace;">@row.P.ToString("N2")</td>
                                    <td style="padding:5px; border:1px solid #e0e0e0; text-align:right; font-family:Consolas,monospace;">@totV.ToString("N2")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
                </div>
                @{
                    var _bTabNot = HesaplaBaskanlikTablosu_Notlar();
                }
                @{
                    // Satışa eklenen kalemlerin özet listesi
                    var _satisDipnotlar = new List<string>();
                    if (_bTabNot.aSarfExtra  > 0) _satisDipnotlar.Add($"A Kotası Kristal — Sarf (Paket üretimi düşüldükten sonra kalan): {_bTabNot.aSarfExtra.ToString("N0")} Kg satışa eklendi");
                    if (_bTabNot.aYemekhane  > 0) _satisDipnotlar.Add($"A Kotası Kristal — Yemekhane tüketimi: {_bTabNot.aYemekhane.ToString("N0")} Kg satışa eklendi");
                    if (_bTabNot.aProms      > 0) _satisDipnotlar.Add($"A Kotası Kristal — Promosyon (PROMS): {_bTabNot.aProms.ToString("N0")} Kg satışa eklendi");
                    if (_bTabNot.pakSarf     > 0) _satisDipnotlar.Add($"A Kotası Paket — Sarf: {_bTabNot.pakSarf.ToString("N0")} Kg satışa eklendi");
                    if (_bTabNot.pakYemekhane > 0) _satisDipnotlar.Add($"A Kotası Paket — Yemekhane tüketimi: {_bTabNot.pakYemekhane.ToString("N0")} Kg satışa eklendi");
                    if (_bTabNot.pakProms    > 0) _satisDipnotlar.Add($"A Kotası Paket — Promosyon (PROMS): {_bTabNot.pakProms.ToString("N0")} Kg satışa eklendi");
                    if (_bTabNot.tkSarfExtra > 0) _satisDipnotlar.Add($"Ticari Kristal — Sarf (Ticari Paket üretimi düşüldükten sonra kalan): {_bTabNot.tkSarfExtra.ToString("N0")} Kg satışa eklendi");
                    if (_bTabNot.tpakSarf    > 0) _satisDipnotlar.Add($"Ticari Paket — Sarf: {_bTabNot.tpakSarf.ToString("N0")} Kg satışa eklendi");
                    if (_bTabNot.bYemekhane  > 0) _satisDipnotlar.Add($"B Kotası — Yemekhane: {_bTabNot.bYemekhane.ToString("N0")} Kg (Diğer Çıkış)");
                    if (_bTabNot.bProms      > 0) _satisDipnotlar.Add($"B Kotası — Promosyon (PROMS): {_bTabNot.bProms.ToString("N0")} Kg (Diğer Çıkış)");
                    if (_bTabNot.cYemekhane  > 0) _satisDipnotlar.Add($"C Şekeri — Yemekhane: {_bTabNot.cYemekhane.ToString("N0")} Kg (Diğer Çıkış)");
                    if (_bTabNot.cProms      > 0) _satisDipnotlar.Add($"C Şekeri — Promosyon (PROMS): {_bTabNot.cProms.ToString("N0")} Kg (Diğer Çıkış)");
                    if (_bTabNot.tkYemekhane > 0) _satisDipnotlar.Add($"Ticari Kristal — Yemekhane: {_bTabNot.tkYemekhane.ToString("N0")} Kg (Diğer Çıkış)");
                    if (_bTabNot.tkProms     > 0) _satisDipnotlar.Add($"Ticari Kristal — Promosyon (PROMS): {_bTabNot.tkProms.ToString("N0")} Kg (Diğer Çıkış)");
                    if (_bTabNot.tpakYemekhane > 0) _satisDipnotlar.Add($"Ticari Paket — Yemekhane: {_bTabNot.tpakYemekhane.ToString("N0")} Kg (Diğer Çıkış)");
                    if (_bTabNot.tpakProms   > 0) _satisDipnotlar.Add($"Ticari Paket — Promosyon (PROMS): {_bTabNot.tpakProms.ToString("N0")} Kg (Diğer Çıkış)");
                }
                @if (_satisDipnotlar.Count > 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                        <b>Satışa Dahil Edilen Kalemler (Sarf / Yemekhane / Promosyon):</b>
                        <ul style="margin:4px 0 0 0; padding-left:18px;">
                            @foreach (var satir in _satisDipnotlar)
                            {
                                <li>@satir</li>
                            }
                        </ul>
                    </MudAlert>
                }
                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-1">
                    <b>Not:</b> Kristal Şeker Satış = LOGO satış + (Sarf - İşlenen) + Yemekhane/PROMS. Paket Şeker Satış = LOGO satış + Sarf + Yemekhane/PROMS. Tüm tutarlar ortalama satış fiyatından hesaplanır.
                </MudAlert>
            </MudPaper>

            @* Özet Kartlar *@
            <MudGrid>
                <MudItem xs="6" sm="4" md="2">
                    <MudCard Style="background-color:#E8F5E9;">
                        <MudCardContent Class="pa-2">
                            <MudText Typo="Typo.caption">Dönem Başı Stok</MudText>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@((_analizSonuc.Sum(x=>x.DonemBasiMiktar)/1000m).ToString("N1")) Ton</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudCard Style="background-color:#E3F2FD;">
                        <MudCardContent Class="pa-2">
                            <MudText Typo="Typo.caption">Toplam Giriş</MudText>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@((_analizSonuc.Sum(x=>x.ToplamGirisMiktar)/1000m).ToString("N1")) Ton</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudCard Style="background-color:#FCE4EC;">
                        <MudCardContent Class="pa-2">
                            <MudText Typo="Typo.caption">Toplam Çıkış</MudText>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@((_analizSonuc.Sum(x=>x.ToplamCikisMiktar)/1000m).ToString("N1")) Ton</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudCard Style="background-color:#FFF3E0;">
                        <MudCardContent Class="pa-2">
                            <MudText Typo="Typo.caption">Toplam Satış</MudText>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@((_analizSonuc.Sum(x=>x.SatisMiktar)/1000m).ToString("N1")) Ton</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudCard Style="background-color:#E8EAF6;">
                        <MudCardContent Class="pa-2">
                            <MudText Typo="Typo.caption">Satış Tutarı</MudText>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@(_analizSonuc.Sum(x=>x.SatisTutar).ToString("N0")) ₺</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudCard Style="background-color:#E65100; color:white;">
                        <MudCardContent Class="pa-2">
                            <MudText Typo="Typo.caption" Style="color:#FFCCBC;">Dönem Sonu Stok</MudText>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@((_analizSonuc.Sum(x=>x.DonemSonuMiktar)/1000m).ToString("N1")) Ton</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        }
            @* ── Dipnotlar (sonraki ay Toptan Satış İade düzeltmeleri) ── *@
            @if (_analizDipnotlar != null && _analizDipnotlar.Count > 0)
            {
                <MudPaper Class="pa-4 mb-4" Style="border-left: 4px solid #F9A825;">
                    <MudText Typo="Typo.subtitle1" Style="color:#E65100; font-weight:700;" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-1" Style="vertical-align:middle;" />
                        Dönem Satış Düzeltme Notları
                    </MudText>
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                        Aşağıdaki tutarlar, raporlanan dönemden <b>sonraki ayda</b> girilen Toptan Satış İade İrsaliyeleri nedeniyle
                        ilgili kategorilerin satış miktarından ve tutarından otomatik olarak düşülmüştür.
                    </MudAlert>
                    @foreach (var d in _analizDipnotlar)
                    {
                        // Brüt satışı (sarf dahil, iade öncesi) hesapla
                        var _hkd = _analizSonuc?.FirstOrDefault(x => x.Kategori == d.HedefKategori);
                        decimal _pakU2 = _analizSonuc?.FirstOrDefault(x=>x.Kategori=="PAKETLI")?.UretimMiktar ?? 0m;
                        decimal _tpU2  = _analizSonuc?.FirstOrDefault(x=>x.Kategori=="TICARI_PAKET")?.UretimMiktar ?? 0m;
                        decimal _brutHB = d.HedefKategori switch {
                            "TICARI_KRISTAL" => (_hkd?.SatisMiktar ?? 0m) + Math.Max(0m, (_hkd?.SarfMiktar ?? 0m) - _tpU2),
                            "A_KOTASI"       => (_hkd?.SatisMiktar ?? 0m) + Math.Max(0m, (_hkd?.SarfMiktar ?? 0m) - _pakU2),
                            "PAKETLI"        => (_hkd?.SatisMiktar ?? 0m) + (_hkd?.SarfMiktar ?? 0m),
                            "TICARI_PAKET"   => (_hkd?.SatisMiktar ?? 0m) + (_hkd?.SarfMiktar ?? 0m),
                            _                => _hkd?.SatisMiktar ?? 0m
                        };
                        decimal dusuldu        = Math.Min(d.Miktar, Math.Max(0m, _brutHB));
                        decimal karsılanamayan = d.Miktar - dusuldu;
                        var dipSev = karsılanamayan > 0 ? Severity.Error : (d.Yonlendirildi ? Severity.Warning : Severity.Normal);
                        <MudAlert Severity="@dipSev" Dense="true" Class="mb-1">
                            <b>@d.SonrakiAyAdi dönemi Toptan Satış İadesi:</b>
                            @if (d.Yonlendirildi)
                            {
                                <span>
                                    <b>@d.KaynakKategoriAdi</b> kategorisinde iade bulundu ancak bu kategoride satış kaydı olmadığından
                                    iade <b>@d.HedefKategoriAdi</b> satışından düşüldü.
                                </span>
                            }
                            else
                            {
                                <span><b>@d.HedefKategoriAdi</b> satışından düşüldü.</span>
                            }
                            <span>&nbsp;| İade: <b>@d.Miktar.ToString("N0") Kg</b> / <b>@d.Tutar.ToString("N2") ₺</b></span>
                            @if (karsılanamayan > 0)
                            {
                                <span style="color:#b71c1c;">
                                    &nbsp;|&nbsp;<b>⚠ Karşılanamayan: @karsılanamayan.ToString("N0") Kg</b>
                                    — bu dönemde @d.HedefKategoriAdi satışı yetersiz olduğundan tüm iade düşülemedi.
                                </span>
                            }
                        </MudAlert>
                    }
                </MudPaper>
            }
        }
        else if (!_analizYukleniyor)
        {
            <MudAlert Severity="Severity.Info">
                Tarih aralığı ve dönem başı stok değerlerini girerek "Analiz Yap" butonuna tıklayın.
            </MudAlert>
        }
    </MudTabPanel>

    @* ══════════════════════════════════════════════════════════════════
       TAB 2 – STOK SORGULA  (VBA CommandButton2 / Module2)
       ══════════════════════════════════════════════════════════════════ *@
    <MudTabPanel Text="Stok Sorgula" Icon="@Icons.Material.Filled.Search">

        <MudPaper Class="pa-4 mb-4">
            <MudGrid>
                <MudItem xs="12" sm="6" md="4">
                    <MudDatePicker Label="Stok Tarihi" @bind-Date="_stokTarihi"
                                   DateFormat="dd.MM.yyyy" Editable="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4" Class="d-flex align-end">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="StokSorgula" Disabled="@_stokYukleniyor">
                        @if (_stokYukleniyor)
                        {
                            <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                        }
                        <MudIcon Icon="@Icons.Material.Filled.Search" Class="mr-1" />
                        Stok Sorgula
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @if (_stokHata != null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_stokHata</MudAlert>
        }

        @if (_stokOzet != null)
        {
            var katOzet = KategoriOzetiHesapla(_stokOzet);
            var genelToplam = katOzet.Sum(x => x.ToplamKg);

            <MudGrid>
                @* KATEGORİ ÖZETİ – Excel ile birebir *@
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" Class="mb-3" Style="color:#1B5E20; font-weight:700;">
                            <MudIcon Icon="@Icons.Material.Filled.PieChart" Class="mr-2" />
                            Şeker Kategorisi – @_stokTarihi?.ToString("dd.MM.yyyy")
                        </MudText>

                        <MudSimpleTable Hover="true" Dense="false" Bordered="true" Style="font-size:0.9rem;">
                            <thead>
                                <tr style="background-color:#2E7D32; color:white;">
                                    <th style="padding:12px 10px; border:1px solid #1B5E20; font-size:0.95rem;">Şeker Kategorisi</th>
                                    <th style="padding:12px 10px; border:1px solid #1B5E20; text-align:right; font-size:0.95rem;">Toplam KG</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var kat in katOzet)
                                {
                                    <tr style="background-color:#fff;">
                                        <td style="padding:10px; border:1px solid #e0e0e0; font-weight:500; font-size:0.9rem;">@kat.KategoriAdi</td>
                                        <td style="padding:10px; border:1px solid #e0e0e0; text-align:right; font-family:Consolas,monospace; font-size:0.9rem;">@kat.ToplamKg.ToString("N2")</td>
                                    </tr>
                                }
                                <tr style="background-color:#E8F5E9; font-weight:700; font-size:1rem;">
                                    <td style="padding:12px 10px; border:2px solid #2E7D32;">TOPLAM</td>
                                    <td style="padding:12px 10px; border:2px solid #2E7D32; text-align:right; font-family:Consolas,monospace; color:#1B5E20;">@genelToplam.ToString("N2")</td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>

                        @* Ton özeti *@
                        <MudAlert Severity="Severity.Success" Dense="true" Class="mt-3">
                            <strong>Genel Toplam:</strong> @((genelToplam / 1000m).ToString("N3")) Ton
                        </MudAlert>
                    </MudPaper>

                    @* Malzeme Kodu Özeti *@
                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.subtitle1" Class="mb-2" Style="color:#1565C0; font-weight:600;">
                            <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-1" />
                            Malzeme Kodu Detayı
                        </MudText>
                        <MudSimpleTable Hover="true" Dense="true" Bordered="true" Style="font-size:0.78rem;">
                            <thead>
                                <tr style="background-color:#1565C0; color:white;">
                                    <th style="padding:6px; border:1px solid #0D47A1;">Malzeme Kodu</th>
                                    <th style="padding:6px; border:1px solid #0D47A1;">Adı</th>
                                    <th style="padding:6px; border:1px solid #0D47A1; text-align:right;">KG</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int ozetSatir = 0; }
                                @foreach (var ozet in _stokOzet)
                                {
                                    var bg = ozetSatir++ % 2 == 0 ? "#fff" : "#f0f4ff";
                                    <tr style="background-color:@bg;">
                                        <td style="padding:5px;border:1px solid #e0e0e0;font-family:Consolas,monospace;font-size:0.72rem;">@ozet.MalzemeKodu</td>
                                        <td style="padding:5px;border:1px solid #e0e0e0;font-size:0.78rem;">@ozet.MalzemeAdi</td>
                                        <td style="padding:5px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;">@ozet.ToplamKg.ToString("N2")</td>
                                    </tr>
                                }
                                <tr style="background-color:#BBDEFB;font-weight:700;">
                                    <td colspan="2" style="padding:6px;border:1px solid #1565C0;">TOPLAM</td>
                                    <td style="padding:6px;border:1px solid #1565C0;text-align:right;font-family:Consolas,monospace;">@_stokOzet.Sum(x=>x.ToplamKg).ToString("N2")</td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudPaper>
                </MudItem>

                @* Detay Tablo *@
                <MudItem xs="12" md="7">
                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" Class="mb-3" Style="color:#4527A0;">
                            <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-2" />
                            Ambar Detayı (@_stokDetay?.Count adet kayıt)
                        </MudText>
                        <div style="overflow-x:auto; max-height:500px; overflow-y:auto;">
                        <MudSimpleTable Hover="true" Dense="true" Bordered="true" Style="font-size:0.75rem;">
                            <thead style="position:sticky; top:0; z-index:1;">
