                        </MudSimpleTable>
                        </div>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
        else if (!_stokYukleniyor)
        {
            <MudAlert Severity="Severity.Info">
                Sorgulamak istediğiniz tarihi seçip "Stok Sorgula" butonuna tıklayın.
            </MudAlert>
        }
    </MudTabPanel>

</MudTabs>

@code {
    // ── Sade Şeker Analizi state ─────────────────────────────────────
    private DateTime? _analizBaslangic = SekerDairesiService.KampanyaBaslangic;
    private DateTime? _analizBitis = DateTime.Today;
    private bool _analizYukleniyor   = false;
    private string? _analizHata      = null;
    private List<SekerKategoriAnaliz>? _analizSonuc;
    private List<SatisIadeDipnot>?    _analizDipnotlar;
    // Başkanlık tablosu dönem başı: önceki aylardaki iade düzeltmeleri aktarılmış
    private Dictionary<string, decimal>? _baskanlikDonemBasi;
    // Başkanlık tablosu dönem sonu: mevcut dönem sonundaki zincir değerleri (AY SONU için)
    private Dictionary<string, decimal>? _baskanlikDonemSonu;

    // ── Stok Sorgula state ───────────────────────────────────────────
    private DateTime? _stokTarihi  = DateTime.Today;
    private bool _stokYukleniyor   = false;
    private string? _stokHata      = null;
    private List<StokDetayRow>? _stokDetay;
    private List<StokOzetRow>?  _stokOzet;

    // ── Analiz Yap ───────────────────────────────────────────────────
    private async Task AnalizYap()
    {
        if (_analizBaslangic == null || _analizBitis == null)
        {
            Snackbar.Add("Lütfen tarih aralığı seçin!", Severity.Warning);
            return;
        }

        _analizYukleniyor = true;
        _analizHata = null;
        try
        {
            var (analiz, dipnotlar) = await SekerDairesiService.GetSadeSekerAnaliziAsync(
                _analizBaslangic.Value,
                _analizBitis.Value);
            _analizSonuc    = analiz;
            _analizDipnotlar = dipnotlar;

            // Başkanlık dönem başı ve dönem sonu: paralel hesapla
            var tBas = SekerDairesiService.GetBaskanlikDonemBasiAsync(_analizBaslangic.Value);
            var tSon = SekerDairesiService.GetBaskanlikDonemBasiAsync(_analizBitis.Value.AddDays(1));
            await Task.WhenAll(tBas, tSon);
            _baskanlikDonemBasi = tBas.Result;
            _baskanlikDonemSonu = tSon.Result;

            var dipNot = dipnotlar.Count > 0 ? $" ({dipnotlar.Count} iade düzeltmesi uygulandı)" : "";
            Snackbar.Add($"Analiz tamamlandı. {_analizSonuc.Count} kategori.{dipNot}", Severity.Success);
        }
        catch (Exception ex)
        {
            _analizHata = $"Analiz sırasında hata: {ex.Message}";
            Snackbar.Add(_analizHata, Severity.Error);
        }
        finally
        {
            _analizYukleniyor = false;
        }
    }

    // ── Stok Sorgula ─────────────────────────────────────────────────
    private async Task StokSorgula()
    {
        if (_stokTarihi == null)
        {
            Snackbar.Add("Lütfen tarih seçin!", Severity.Warning);
            return;
        }

        _stokYukleniyor = true;
        _stokHata = null;
        try
        {
            var (detay, ozet) = await SekerDairesiService.GetStokSorgulaAsync(_stokTarihi.Value);
            _stokDetay = detay;
            _stokOzet  = ozet;
            Snackbar.Add($"Stok sorgusu tamamlandı. {detay.Count} kayıt bulundu.", Severity.Success);
        }
        catch (Exception ex)
        {
            _stokHata = $"Stok sorgusunda hata: {ex.Message}";
            Snackbar.Add(_stokHata, Severity.Error);
        }
        finally
        {
            _stokYukleniyor = false;
        }
    }

    // ── Şeker Dairesi Başkanlığı tablo yardımcıları ──────────────────
    private enum BRowTip { GrupBaslik, Veri, ToplamSatir, TutarSatir, FiyatSatir }
    private record BRow(BRowTip Tip, string Ad, decimal K = 0m, decimal P = 0m, decimal? TotOverride = null);

    private SekerKategoriAnaliz? GetKat(string key) =>
        _analizSonuc?.FirstOrDefault(x => x.Kategori == key);

    private (decimal aYemProms, decimal pakYemProms,
             decimal aSarfExtra, decimal tkSarfExtra,
             decimal pakSarf, decimal tpakSarf,
             decimal aYemekhane, decimal aProms,
             decimal pakYemekhane, decimal pakProms,
             decimal bYemekhane, decimal bProms,
             decimal cYemekhane, decimal cProms,
             decimal tkYemekhane, decimal tkProms,
             decimal tpakYemekhane, decimal tpakProms)
        HesaplaBaskanlikTablosu_Notlar()
    {
        var a    = GetKat("A_KOTASI");
        var b    = GetKat("B_KOTASI");
        var c    = GetKat("C_KOTASI");
        var tk   = GetKat("TICARI_KRISTAL");
        var pak  = GetKat("PAKETLI");
        var tpak = GetKat("TICARI_PAKET");

        decimal pakUretim  = pak?.UretimMiktar  ?? 0m;
        decimal tpakUretim = tpak?.UretimMiktar ?? 0m;
        decimal aSarfExtra  = Math.Max(0m, (a?.SarfMiktar  ?? 0m) - pakUretim);
        decimal tkSarfExtra = Math.Max(0m, (tk?.SarfMiktar ?? 0m) - tpakUretim);

        return (
            aYemProms:      (a?.YemekhaneMiktar   ?? 0m) + (a?.PromsMiktar   ?? 0m),
            pakYemProms:    (pak?.YemekhaneMiktar  ?? 0m) + (pak?.PromsMiktar  ?? 0m),
            aSarfExtra:     aSarfExtra,
            tkSarfExtra:    tkSarfExtra,
            pakSarf:        pak?.SarfMiktar  ?? 0m,
            tpakSarf:       tpak?.SarfMiktar ?? 0m,
            aYemekhane:     a?.YemekhaneMiktar   ?? 0m,
            aProms:         a?.PromsMiktar       ?? 0m,
            pakYemekhane:   pak?.YemekhaneMiktar  ?? 0m,
            pakProms:       pak?.PromsMiktar      ?? 0m,
            bYemekhane:     b?.YemekhaneMiktar   ?? 0m,
            bProms:         b?.PromsMiktar       ?? 0m,
            cYemekhane:     c?.YemekhaneMiktar   ?? 0m,
            cProms:         c?.PromsMiktar       ?? 0m,
            tkYemekhane:    tk?.YemekhaneMiktar  ?? 0m,
            tkProms:        tk?.PromsMiktar      ?? 0m,
            tpakYemekhane:  tpak?.YemekhaneMiktar ?? 0m,
            tpakProms:      tpak?.PromsMiktar     ?? 0m
        );
    }

    private List<BRow> HesaplaBaskanlikTablosu()
    {
        if (_analizSonuc == null) return [];

        var a    = GetKat("A_KOTASI");
        var b    = GetKat("B_KOTASI");
        var c    = GetKat("C_KOTASI");
        var tk   = GetKat("TICARI_KRISTAL");
        var knya = GetKat("KONYA_TICARI");
        var pak  = GetKat("PAKETLI");
        var tpak = GetKat("TICARI_PAKET");

        decimal pakUretim  = pak?.UretimMiktar  ?? 0m;
        decimal tpakUretim = tpak?.UretimMiktar ?? 0m;

        // ── 1. Sarf extrayı hesapla (paket üretimi düşüldükten sonra kalan sarf)
        decimal aSarfExtra  = Math.Max(0m, (a?.SarfMiktar  ?? 0m) - pakUretim);
        decimal tkSarfExtra = Math.Max(0m, (tk?.SarfMiktar ?? 0m) - tpakUretim);

        // ── 2. Ortalama LOGO satış fiyatından sarf tutarını hesapla
        //    (kullanıcının istediği mantık: ort. satış fiyatı × sarf miktarı)
        decimal aOrtFiyat   = (a?.SatisMiktar  ?? 0m) > 0 ? (a?.SatisTutar  ?? 0m) / (a?.SatisMiktar  ?? 0m) : 0m;
        // Konya Şeker satışı Ticari Kristal'e ekleniyor — ortalama fiyat her ikisi dahil hesaplanır
        decimal tkToplamSatisMiktar = (tk?.SatisMiktar ?? 0m) + (knya?.SatisMiktar ?? 0m);
        decimal tkToplamSatisTutar  = (tk?.SatisTutar  ?? 0m) + (knya?.SatisTutar  ?? 0m);
        decimal tkOrtFiyat  = tkToplamSatisMiktar > 0 ? tkToplamSatisTutar / tkToplamSatisMiktar : 0m;
        decimal pakOrtFiyat = (pak?.SatisMiktar  ?? 0m) > 0 ? (pak?.SatisTutar  ?? 0m) / (pak?.SatisMiktar  ?? 0m) : 0m;
        decimal tpOrtFiyat  = (tpak?.SatisMiktar ?? 0m) > 0 ? (tpak?.SatisTutar ?? 0m) / (tpak?.SatisMiktar ?? 0m) : 0m;

        decimal aSarfExtraTutar  = aOrtFiyat  * aSarfExtra;
        decimal tkSarfExtraTutar = tkOrtFiyat * tkSarfExtra;
        decimal pakSarfTutar     = pakOrtFiyat * (pak?.SarfMiktar  ?? 0m);
        decimal tpSarfTutar      = tpOrtFiyat  * (tpak?.SarfMiktar ?? 0m);

        // ── 3. Toplam satış (LOGO satış + sarf + A/Paket yemekhane&PROMS) — iade öncesi
        // Yemekhane+PROMS için ayrı değişkenler (Diğer Çıkış bloğundan önce tanımlanmış)
        decimal aYemPromsLocal   = (a?.YemekhaneMiktar  ?? 0m) + (a?.PromsMiktar  ?? 0m);
        decimal pakYemPromsLocal = (pak?.YemekhaneMiktar ?? 0m) + (pak?.PromsMiktar ?? 0m);
        decimal aYemPromsTutar   = aOrtFiyat   * aYemPromsLocal;
        decimal pakYemPromsTutar = pakOrtFiyat * pakYemPromsLocal;

        decimal aSatisBrüt    = (a?.SatisMiktar  ?? 0m) + aSarfExtra   + aYemPromsLocal;
        decimal aSatisBrütTl  = (a?.SatisTutar   ?? 0m) + aSarfExtraTutar + aYemPromsTutar;
        decimal tkSatisBrüt   = (tk?.SatisMiktar ?? 0m) + tkSarfExtra + (knya?.SatisMiktar ?? 0m);
        decimal tkSatisBrütTl = (tk?.SatisTutar  ?? 0m) + tkSarfExtraTutar + (knya?.SatisTutar ?? 0m);
        decimal pakSatisBrüt  = (pak?.SatisMiktar  ?? 0m) + (pak?.SarfMiktar  ?? 0m) + pakYemPromsLocal;
        decimal pakSatisBrütTl= (pak?.SatisTutar   ?? 0m) + pakSarfTutar + pakYemPromsTutar;
        decimal tpSatisBrüt   = (tpak?.SatisMiktar ?? 0m) + (tpak?.SarfMiktar ?? 0m);
        decimal tpSatisBrütTl = (tpak?.SatisTutar  ?? 0m) + tpSarfTutar;

        // ── Başkanlık dönem başı değerleri (iade düzeltmeleri dahil)
        decimal bkA   = _baskanlikDonemBasi?.GetValueOrDefault("A_KOTASI")       ?? (a?.DonemBasiMiktar   ?? 0m);
        decimal bkPak = _baskanlikDonemBasi?.GetValueOrDefault("PAKETLI")        ?? (pak?.DonemBasiMiktar  ?? 0m);
        decimal bkB   = _baskanlikDonemBasi?.GetValueOrDefault("B_KOTASI")       ?? (b?.DonemBasiMiktar   ?? 0m);
        decimal bkC   = _baskanlikDonemBasi?.GetValueOrDefault("C_KOTASI")       ?? (c?.DonemBasiMiktar   ?? 0m);
        decimal bkTK  = _baskanlikDonemBasi?.GetValueOrDefault("TICARI_KRISTAL") ?? (tk?.DonemBasiMiktar  ?? 0m);
        decimal bkTP  = _baskanlikDonemBasi?.GetValueOrDefault("TICARI_PAKET")   ?? (tpak?.DonemBasiMiktar ?? 0m);

        // ── Başkanlık satış yönlendirmesi: bkTK/bkTP stoğu varsa A/Paket çıkışları önce
        //    Ticari Mal'dan tüketilir (portal mantığı).
        // LOGO analizi zaten logoTK_başı = tk?.DonemBasiMiktar kadar A→TK yapmıştır.
        // Başkanlık'ın EKSTRA yaptığı = bkTK - logoTK_başı kadar daha fazla tüketim.
        decimal logoTKStart = tk?.DonemBasiMiktar   ?? 0m;
        decimal logoTPStart = tpak?.DonemBasiMiktar ?? 0m;
        decimal R_TK = Math.Max(0m, Math.Min(aSatisBrüt,   bkTK - logoTKStart));
        decimal R_TP = Math.Max(0m, Math.Min(pakSatisBrüt,  bkTP - logoTPStart));
        // Yönlendirilmiş tutarlar (A'nın ortalama fiyatıyla)
        decimal R_TK_Tl = aSatisBrüt  > 0 ? aSatisBrütTl  * R_TK / aSatisBrüt  : 0m;
        decimal R_TP_Tl = pakSatisBrüt > 0 ? pakSatisBrütTl * R_TP / pakSatisBrüt : 0m;
        // Başkanlık brüt satışlar (yönlendirme sonrası)
        decimal bkASatisBrüt    = aSatisBrüt    - R_TK;
        decimal bkASatisBrütTl  = aSatisBrütTl  - R_TK_Tl;
        decimal bkTKSatisBrüt   = tkSatisBrüt   + R_TK;
        decimal bkTKSatisBrütTl = tkSatisBrütTl + R_TK_Tl;
        decimal bkPakSatisBrüt    = pakSatisBrüt    - R_TP;
        decimal bkPakSatisBrütTl  = pakSatisBrütTl  - R_TP_Tl;
        decimal bkTPSatisBrüt   = tpSatisBrüt   + R_TP;
        decimal bkTPSatisBrütTl = tpSatisBrütTl + R_TP_Tl;

        // ── Sonraki ay iade düzeltmelerini Başkanlık brüt üzerinden uygula
        decimal IadeHesapla(string kat, decimal brutMiktar) =>
            Math.Min(brutMiktar, Math.Max(0m,
                (_analizDipnotlar ?? []).Where(d => d.HedefKategori == kat).Sum(d => d.Miktar)));
        decimal IadeTutar(decimal iadeMiktar, decimal brutMiktar, decimal brutTutar) =>
            brutMiktar > 0 ? brutTutar * iadeMiktar / brutMiktar : 0m;

        decimal aIadeMiktar   = IadeHesapla("A_KOTASI", bkASatisBrüt);
        // Konya Şeker iadeleri de Ticari Kristal toplamına dahil edilir
        decimal tkIadeMiktar  = Math.Min(bkTKSatisBrüt, Math.Max(0m,
            (_analizDipnotlar ?? []).Where(d => d.HedefKategori == "TICARI_KRISTAL" || d.HedefKategori == "KONYA_TICARI").Sum(d => d.Miktar)));
        decimal pakIadeMiktar = IadeHesapla("PAKETLI",      bkPakSatisBrüt);
        decimal tpIadeMiktar  = IadeHesapla("TICARI_PAKET", bkTPSatisBrüt);

        decimal aIadeTutar   = IadeTutar(aIadeMiktar,  bkASatisBrüt,    bkASatisBrütTl);
        decimal tkIadeTutar  = IadeTutar(tkIadeMiktar, bkTKSatisBrüt,   bkTKSatisBrütTl);
        decimal pakIadeTutar = IadeTutar(pakIadeMiktar, bkPakSatisBrüt,  bkPakSatisBrütTl);
        decimal tpIadeTutar  = IadeTutar(tpIadeMiktar,  bkTPSatisBrüt,   bkTPSatisBrütTl);

        // ── Net satış = Başkanlık brüt - iade
        decimal aSatisMiktar  = bkASatisBrüt    - aIadeMiktar;
        decimal aSatisTutar   = bkASatisBrütTl  - aIadeTutar;
        decimal tkSatisMiktar = bkTKSatisBrüt   - tkIadeMiktar;
        decimal tkSatisTutar  = bkTKSatisBrütTl - tkIadeTutar;

        // ── Paket Satış = brüt - iade
        decimal pakSatisMiktar  = bkPakSatisBrüt   - pakIadeMiktar;
        decimal pakSatisTutar   = bkPakSatisBrütTl - pakIadeTutar;
        decimal tpakSatisMiktar = bkTPSatisBrüt    - tpIadeMiktar;
        decimal tpakSatisTutar  = bkTPSatisBrütTl  - tpIadeTutar;

        // ── Diğer Yollarla Çıkış: sadece TİCARİ MAL kategorileri (Yemekhane + PROMS)
        // A Kotası ve Paket kategorilerinin Yemekhane+PROMS'u SATIŞA eklenir (Bakanlık zorunluluğu)
        decimal aYemProms   = (a?.YemekhaneMiktar   ?? 0m) + (a?.PromsMiktar   ?? 0m);
        decimal pakYemProms = (pak?.YemekhaneMiktar  ?? 0m) + (pak?.PromsMiktar  ?? 0m);
        decimal bDigerK     = (b?.YemekhaneMiktar   ?? 0m) + (b?.PromsMiktar   ?? 0m);
        decimal cDigerK     = (c?.YemekhaneMiktar   ?? 0m) + (c?.PromsMiktar   ?? 0m);
        decimal tkDigerK    = (tk?.YemekhaneMiktar  ?? 0m) + (tk?.PromsMiktar  ?? 0m);
        decimal tpakDigerP  = (tpak?.YemekhaneMiktar ?? 0m) + (tpak?.PromsMiktar ?? 0m);

        var r = new List<BRow>();

        // ── AY BAŞI STOK ──────────────────────────────────────────────
        // Başkanlık tablosunda dönem başı = _baskanlikDonemBasi (iade düzeltmeleri dahil)
        r.Add(new(BRowTip.GrupBaslik, "AY BAŞI STOK"));
        r.Add(new(BRowTip.Veri, "Şirkete Ait Stok (Şeker Türleri İçin A Kotası)", bkA, bkPak));
        r.Add(new(BRowTip.Veri, "Şirkete Ait Stok (Şeker Türleri İçin B Kotası)", bkB));
        r.Add(new(BRowTip.Veri, "Şirkete Ait Stok (Şeker Türleri İçin C Şekeri)", bkC));
        r.Add(new(BRowTip.Veri, "Ticari Mal Stok", bkTK, bkTP));
        r.Add(new(BRowTip.ToplamSatir, "Aylık \"Ay Başı Stok\" Toplam",
            bkA + bkB + bkC + bkTK,
            bkPak + bkTP));

        // ── SATINALMA ──────────────────────────────────────────────────
        r.Add(new(BRowTip.GrupBaslik, "SATINALMA / SATIN ALINAN"));
        // Konya Şeker satın alması da Ticari Kristal satırına eklenir (satışları da oraya ekleniyor)
        decimal tkSatinAlma = (tk?.SatinAlmaMiktar ?? 0m) + (knya?.SatinAlmaMiktar ?? 0m);
        r.Add(new(BRowTip.Veri, "Yurtiçinden Satın Alınan (Ticari Mal)", tkSatinAlma, tpak?.SatinAlmaMiktar ?? 0m));
        r.Add(new(BRowTip.Veri, "Yurtdışından Satın Alınan"));
        r.Add(new(BRowTip.Veri, "Fason Üretim İçin Teslim Alınan"));
        r.Add(new(BRowTip.ToplamSatir, "Aylık \"Satın Alınan\" Toplam",
            tkSatinAlma, tpak?.SatinAlmaMiktar ?? 0m));

        // ── İŞLENEN ───────────────────────────────────────────────────
        r.Add(new(BRowTip.GrupBaslik, "İŞLENEN"));
        r.Add(new(BRowTip.Veri, "Şirkete Ait İşlenen A Kotası", pakUretim));
        r.Add(new(BRowTip.Veri, "Şirkete Ait İşlenen B Kotası"));
        r.Add(new(BRowTip.Veri, "Şirkete Ait İşlenen C Şekeri"));
        r.Add(new(BRowTip.Veri, "Ticari Mal İşlenen", tpakUretim));
        r.Add(new(BRowTip.Veri, "Fason İşlenen"));
        r.Add(new(BRowTip.ToplamSatir, "Aylık \"İşlenen\" Toplam", pakUretim + tpakUretim));

        // ── ÜRETİM ────────────────────────────────────────────────────
        r.Add(new(BRowTip.GrupBaslik, "ÜRETİM"));
        r.Add(new(BRowTip.Veri, "Şirkete Ait Üretim (Şeker Türleri İçin A Kotası)", a?.UretimMiktar ?? 0m, pakUretim));
        r.Add(new(BRowTip.Veri, "Şirkete Ait Üretim (Şeker Türleri İçin B Kotası)", b?.UretimMiktar ?? 0m));
        r.Add(new(BRowTip.Veri, "Şirkete Ait Üretim (Şeker Türleri İçin C Şekeri)", c?.UretimMiktar ?? 0m));
        r.Add(new(BRowTip.Veri, "Fason Üretim"));
        r.Add(new(BRowTip.Veri, "Ticari Mal Üretimi", tk?.UretimMiktar ?? 0m, tpakUretim));
        r.Add(new(BRowTip.ToplamSatir, "Aylık \"Üretim\" Toplam",
            (a?.UretimMiktar ?? 0m) + (b?.UretimMiktar ?? 0m) + (c?.UretimMiktar ?? 0m) + (tk?.UretimMiktar ?? 0m),
            pakUretim + tpakUretim));

        // ── DİĞER YOLLARLA GİRİŞ ─────────────────────────────────────
        r.Add(new(BRowTip.GrupBaslik, "DİĞER YOLLARLA GİRİŞ"));
        r.Add(new(BRowTip.Veri, "Giriş (A Kotası)"));
        r.Add(new(BRowTip.Veri, "Giriş (B Kotası)"));
        r.Add(new(BRowTip.Veri, "Giriş (C Şekeri)"));
        r.Add(new(BRowTip.Veri, "Giriş Fason"));
        r.Add(new(BRowTip.Veri, "Giriş Ticari Mal"));
        r.Add(new(BRowTip.ToplamSatir, "Aylık \"Diğer Yollarla Giriş\" Toplam"));

        // ── DİĞER YOLLARLA ÇIKIŞ: sadece Ticari Mal yemekhane+PROMS
        // A Kotası ve Paket'in yemekhane+PROMS'u satışa eklendi (Bakanlık zorunluluğu)
        r.Add(new(BRowTip.GrupBaslik, "DİĞER YOLLARLA ÇIKIŞ"));
        r.Add(new(BRowTip.Veri, "Çıkış (A Kotası)"));
        r.Add(new(BRowTip.Veri, "Çıkış (B Kotası)", bDigerK));
        r.Add(new(BRowTip.Veri, "Çıkış (C Şekeri)", cDigerK));
        r.Add(new(BRowTip.Veri, "Çıkış Fason"));
        r.Add(new(BRowTip.Veri, "Çıkış Ticari Mal", tkDigerK, tpakDigerP));
        decimal digCikisK = bDigerK + cDigerK + tkDigerK;
        decimal digCikisP = tpakDigerP;
        r.Add(new(BRowTip.ToplamSatir, "Aylık \"Diğer Yollarla Çıkış\" Toplam", digCikisK, digCikisP));

        // ── SATIŞ ─────────────────────────────────────────────────────
        r.Add(new(BRowTip.GrupBaslik, "SATIŞ (Satış ve/veya Teslim Eden)"));
        r.Add(new(BRowTip.Veri, "Yurtiçi Satış (Şeker Türleri İçin A Kotası)", aSatisMiktar, pakSatisMiktar));
        r.Add(new(BRowTip.Veri, "Yurtiçi Satış (Şeker Türleri İçin B Kotası)", b?.SatisMiktar ?? 0m));
        r.Add(new(BRowTip.Veri, "C Şekeri Satışı (Toplam)", c?.SatisMiktar ?? 0m));
        r.Add(new(BRowTip.Veri, "Yurtiçi Ticari Mal Satışı", tkSatisMiktar, tpakSatisMiktar));
        r.Add(new(BRowTip.Veri, "Yurtdışı Ticari Mal Satışı"));
        decimal satisK = aSatisMiktar + (b?.SatisMiktar ?? 0m) + (c?.SatisMiktar ?? 0m) + tkSatisMiktar;
        decimal satisP = pakSatisMiktar + tpakSatisMiktar;
        r.Add(new(BRowTip.ToplamSatir, "Aylık \"Satış ve/veya Teslim Edilen\" Toplam", satisK, satisP));

        // Hasılat (TL) — sarf payı dahil
        r.Add(new(BRowTip.TutarSatir, "A Kotası Satış Hâsılatı (TL)", aSatisTutar, pakSatisTutar));
        r.Add(new(BRowTip.TutarSatir, "B Kotası Satış Hâsılatı (TL)", b?.SatisTutar ?? 0m));
        r.Add(new(BRowTip.TutarSatir, "C Şekeri Satış Hâsılatı (TL)", c?.SatisTutar ?? 0m));
        r.Add(new(BRowTip.TutarSatir, "Ticari Mal Satış Hâsılatı (TL)", tkSatisTutar, tpakSatisTutar));
        decimal ciroK = aSatisTutar + (b?.SatisTutar ?? 0m) + (c?.SatisTutar ?? 0m) + tkSatisTutar;
        decimal ciroP = pakSatisTutar + tpakSatisTutar;
        r.Add(new(BRowTip.TutarSatir, "Toplam Ciro", ciroK, ciroP));

        // Fiyat Ortalaması (TL/Kg) — sarf payı dahil
        decimal aKFiyat   = aSatisMiktar    > 0 ? aSatisTutar    / aSatisMiktar    : 0m;
        decimal aPFiyat   = pakSatisMiktar  > 0 ? pakSatisTutar  / pakSatisMiktar  : 0m;
        decimal aFiyatT   = (aSatisMiktar + pakSatisMiktar) > 0
            ? (aSatisTutar + pakSatisTutar) / (aSatisMiktar + pakSatisMiktar) : 0m;

        decimal bFiyat    = (b?.SatisMiktar ?? 0m) > 0 ? (b?.SatisTutar ?? 0m) / b!.SatisMiktar : 0m;
        decimal cFiyat    = (c?.SatisMiktar ?? 0m) > 0 ? (c?.SatisTutar ?? 0m) / c!.SatisMiktar : 0m;

        decimal tkKFiyat  = tkSatisMiktar   > 0 ? tkSatisTutar   / tkSatisMiktar   : 0m;
        decimal tkPFiyat  = tpakSatisMiktar > 0 ? tpakSatisTutar / tpakSatisMiktar : 0m;
        decimal tkFiyatT  = (tkSatisMiktar + tpakSatisMiktar) > 0
            ? (tkSatisTutar + tpakSatisTutar) / (tkSatisMiktar + tpakSatisMiktar) : 0m;

        r.Add(new(BRowTip.FiyatSatir, "Aylık Fiyat Ortalaması – A Kotası (KDV hariç, TL/Kg)", aKFiyat, aPFiyat, aFiyatT));
        r.Add(new(BRowTip.FiyatSatir, "Aylık Fiyat Ortalaması – B Kotası (KDV hariç, TL/Kg)", bFiyat, 0m, bFiyat));
        r.Add(new(BRowTip.FiyatSatir, "Aylık Fiyat Ortalaması – C Şekeri (KDV hariç, TL/Kg)", cFiyat, 0m, cFiyat));
        r.Add(new(BRowTip.FiyatSatir, "Aylık Fiyat Ortalaması – Ticari Mal (KDV hariç, TL/Kg)", tkKFiyat, tkPFiyat, tkFiyatT));

        // ── AY SONU STOK (Başkanlık Portalı ile Uyumlu) ──────────────────────
        // Formül: Başkanlık Dönem Başı + (LOGO bu ay net değişim) + sonraki ay iadeleri
        //
        //  Başkanlık Dönem Başı: önceki ayda uygulanan iade düzeltmeleri dahil
        //    (portala girilen önceki ay sonu stoğuyla eşleşir)
        //  LOGO net değişim: DonemSonuMiktar - DonemBasiMiktar (üretim-satış-sarf farkı)
        //  Sonraki ay iadeleri: dipnotlardaki iadeler satıştan düşüldüğü için stoka eklenir
        //
        //  İade yoksa → Başkanlık Sonu = Başkanlık Başı + LOGO net değişim
        //  İade varsa → Başkanlık Sonu > LOGO Sonu (kasım iadeleri ekim stoğunu artırır)

        // AY SONU: Başkanlık zincir çıktısı kullanılır (bir sonraki ayın AY BAŞI ile tutarlı).
        // _baskanlikDonemSonu = GetBaskanlikDonemBasiAsync(bitis+1) → bu dönem sonu zincir değeri.
        decimal bIadeMiktar   = IadeHesapla("B_KOTASI", b?.SatisMiktar ?? 0m);
        decimal cIadeMiktar   = IadeHesapla("C_KOTASI", c?.SatisMiktar ?? 0m);
        decimal aKristalSonu  = _baskanlikDonemSonu?.GetValueOrDefault("A_KOTASI")
            ?? bkA   + (a?.DonemSonuMiktar   ?? 0m) - (a?.DonemBasiMiktar   ?? 0m) + R_TK  + aIadeMiktar;
        decimal aPaketSonu    = _baskanlikDonemSonu?.GetValueOrDefault("PAKETLI")
            ?? bkPak + (pak?.DonemSonuMiktar  ?? 0m) - (pak?.DonemBasiMiktar  ?? 0m) + R_TP  + pakIadeMiktar;
        decimal bSonu         = _baskanlikDonemSonu?.GetValueOrDefault("B_KOTASI")
            ?? bkB   + (b?.DonemSonuMiktar   ?? 0m) - (b?.DonemBasiMiktar   ?? 0m) + bIadeMiktar;
        decimal cSonu         = _baskanlikDonemSonu?.GetValueOrDefault("C_KOTASI")
            ?? bkC   + (c?.DonemSonuMiktar   ?? 0m) - (c?.DonemBasiMiktar   ?? 0m) + cIadeMiktar;
        decimal tkKristalSonu = _baskanlikDonemSonu?.GetValueOrDefault("TICARI_KRISTAL")
            ?? bkTK  + (tk?.DonemSonuMiktar  ?? 0m) - (tk?.DonemBasiMiktar  ?? 0m)
                     + (knya?.DonemSonuMiktar ?? 0m) - (knya?.DonemBasiMiktar ?? 0m) - R_TK + tkIadeMiktar;
        decimal tpakSonu      = _baskanlikDonemSonu?.GetValueOrDefault("TICARI_PAKET")
            ?? bkTP  + (tpak?.DonemSonuMiktar ?? 0m) - (tpak?.DonemBasiMiktar ?? 0m) - R_TP + tpIadeMiktar;

        r.Add(new(BRowTip.GrupBaslik, "AY SONU STOK (Portal ile Uyumlu)"));
        r.Add(new(BRowTip.Veri, "Ay Sonu Stok – A Kotası (Kristal / Paket)", aKristalSonu, aPaketSonu));
        r.Add(new(BRowTip.Veri, "Ay Sonu Stok – B Kotası",                   bSonu));
        r.Add(new(BRowTip.Veri, "Ay Sonu Stok – C Şekeri",                   cSonu));
        r.Add(new(BRowTip.Veri, "Ay Sonu Stok – Ticari Mal (Kristal / Paket)", tkKristalSonu, tpakSonu));
        decimal aysonuK = aKristalSonu + bSonu + cSonu + tkKristalSonu;
        decimal aysonuP = aPaketSonu + tpakSonu;
        r.Add(new(BRowTip.ToplamSatir, "Aylık \"Ay Sonu Stok\" Toplam", aysonuK, aysonuP,
            aysonuK + aysonuP));

        return r;
    }

    // ── Kategori özeti (Excel ile birebir) ───────────────────────────
    private record KatOzetRow(string KategoriAdi, decimal ToplamKg);

    private List<KatOzetRow> KategoriOzetiHesapla(List<StokOzetRow> ozetler)
    {
        var gruplar = new Dictionary<string, decimal>
        {
            ["C Şekeri"] = 0m,
            ["B Şekeri"] = 0m,
            ["A Şekeri"] = 0m,
            ["Paketli Şeker"] = 0m,
        };

        foreach (var ozet in ozetler)
        {
            var kat = MalzemeKategoriAdi(ozet.MalzemeAdi, ozet.MalzemeKodu);
            if (gruplar.ContainsKey(kat))
                gruplar[kat] += ozet.ToplamKg;
            else
                gruplar["Paketli Şeker"] += ozet.ToplamKg;
        }

        return gruplar
            .Where(kvp => kvp.Value != 0m)
            .Select(kvp => new KatOzetRow(kvp.Key, kvp.Value))
            .ToList();
    }

    private static string MalzemeKategoriAdi(string ad, string kod)
    {
        var adUpper = (ad ?? "").ToUpperInvariant();
        if (adUpper.Contains("A KOTASI") || adUpper.Contains("A KOTA")) return "A Şekeri";
        if (adUpper.Contains("B KOTASI") || adUpper.Contains("B KOTA")) return "B Şekeri";
        if (adUpper.Contains("C KOTASI") || adUpper.Contains("C KOTA")) return "C Şekeri";

        return kod.Trim() switch
        {
            "S.T.0.0.0" or "S.T.0.0.4" or "S.705.00.0005" => "A Şekeri",
            "S.T.0.0.8" or "S.705.00.0001"                 => "B Şekeri",
            "S.T.0.0.7" or "S.705.00.0008"                 => "C Şekeri",
            _                                               => "Paketli Şeker",
        };
    }

    // ── Hızlı tarih seçimi ───────────────────────────────────────────
    private void SetAnalizAraligi(int tip)
    {
        var today = DateTime.Today;
        switch (tip)
        {
            case 0:
                _analizBaslangic = new DateTime(today.Year, today.Month, 1);
                _analizBitis     = today;
                break;
            case 1:
                _analizBaslangic = new DateTime(today.Year, 1, 1);
                _analizBitis     = today;
                break;
            case 2:
                var gAy = today.AddMonths(-1);
                _analizBaslangic = new DateTime(gAy.Year, gAy.Month, 1);
                _analizBitis     = new DateTime(gAy.Year, gAy.Month,
                    DateTime.DaysInMonth(gAy.Year, gAy.Month));
                break;
        }
    }
