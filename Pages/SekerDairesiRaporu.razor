                                    <th style="padding:6px 4px; border:1px solid #311B92;">Malzeme Adı</th>
                                    <th style="padding:6px 4px; border:1px solid #311B92; text-align:right;">Birim</th>
                                    <th style="padding:6px 4px; border:1px solid #311B92; text-align:right;">Stok</th>
                                    <th style="padding:6px 4px; border:1px solid #311B92; text-align:right;">KG</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (_stokDetay != null)
                                {
                                    int detaySatir = 0;
                                    @foreach (var d in _stokDetay)
                                    {
                                        var bg = detaySatir++ % 2 == 0 ? "#fff" : "#f3f0ff";
                                        <tr style="background-color:@bg;">
                                            <td style="padding:4px;border:1px solid #e0e0e0;text-align:center;">@d.AmbarNo</td>
                                            <td style="padding:4px;border:1px solid #e0e0e0;">@d.Ambar</td>
                                            <td style="padding:4px;border:1px solid #e0e0e0;font-family:Consolas,monospace;font-size:0.7rem;">@d.MalzemeKodu</td>
                                            <td style="padding:4px;border:1px solid #e0e0e0;">@d.MalzemeAdi</td>
                                            <td style="padding:4px;border:1px solid #e0e0e0;text-align:center;">@d.AnaBirim</td>
                                            <td style="padding:4px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;">@d.Stok.ToString("N2")</td>
                                            <td style="padding:4px;border:1px solid #e0e0e0;text-align:right;font-family:Consolas,monospace;">@(d.Kg?.ToString("N2") ?? "-")</td>
