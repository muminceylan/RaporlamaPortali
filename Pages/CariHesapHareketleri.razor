@page "/cari-hareket"
@using RaporlamaPortali.Models
@using RaporlamaPortali.Services
@inject LogoIslemleriService Logo
@inject ExcelExportService ExcelExportService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Cari Hesap Hareketleri</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Class="mr-2" />
    Cari Hesap Hareketleri
</MudText>

<MudAlert Severity="Severity.Info" Class="mb-3" Dense="true">
    Logo <b>LG_211_01_CLFLINE</b> × <b>LG_211_CLCARD</b> tablolarından seçilen cari hesabın
    tarih aralığındaki BORÇ / ALACAK hareketleri ve kümülatif BAKİYE değeri listelenir.
</MudAlert>

<MudPaper Class="pa-3 mb-3">
    <MudGrid>
        <MudItem xs="12" md="3">
            <MudDatePicker @bind-Date="_baslangic" Label="Başlangıç" DateFormat="dd.MM.yyyy"
                           Editable="true" Mask="@(new DateMask("dd.MM.yyyy"))"
                           Variant="Variant.Outlined" Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudDatePicker @bind-Date="_bitis" Label="Bitiş" DateFormat="dd.MM.yyyy"
                           Editable="true" Mask="@(new DateMask("dd.MM.yyyy"))"
                           Variant="Variant.Outlined" Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="12" md="6">
            <MudAutocomplete T="CariSecenek"
                             Label="Cari Hesap (kod, ünvan, TC, VKN)"
                             Variant="Variant.Outlined" Margin="Margin.Dense"
                             SearchFunc="@CariAra"
                             ToStringFunc="@(c => c == null ? "" : c.Etiket)"
                             Value="_seciliCari"
                             ValueChanged="@OnCariChanged"
                             Clearable="true"
                             Dense="true"
                             CoerceText="false"
                             MaxItems="50"
                             ResetValueOnEmptyText="true"
                             ShowProgressIndicator="true" />
        </MudItem>

        <MudItem xs="12" md="6" Class="d-flex align-center gap-2">
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Search"
                       OnClick="VeriYukle" Disabled="_yukleniyor">
                @(_yukleniyor ? "Yükleniyor..." : "Getir")
            </MudButton>
            <MudButton Color="Color.Success" Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.FileDownload"
                       OnClick="ExcelIndir" Disabled="_hareketler.Count == 0">
                Excel
            </MudButton>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudTextField @bind-Value="_aramaGenel" Label="Arama (büyük/küçük harf duyarsız)"
                          Placeholder="Fiş türü, fiş no, açıklama, cari kodu/ünvanı"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Immediate="true" DebounceInterval="300" />
        </MudItem>

        <MudItem xs="12">
            @{
                var topBorc = FiltreliKayit.Sum(x => x.Borc);
                var topAlacak = FiltreliKayit.Sum(x => x.Alacak);
                var netBak = topBorc - topAlacak;
                var netDurum = netBak < 0 ? "Firma ALACAKLI" : (netBak > 0 ? "Firma BORÇLU" : "EŞİT");
                var netRenk = netBak < 0 ? "#2e7d32" : (netBak > 0 ? "#c62828" : "#555");
                var dovizGruplari = FiltreliKayit
                    .Where(x => x.TrCurr != 0 && !string.IsNullOrEmpty(x.DovizKodu))
                    .GroupBy(x => x.DovizKodu)
                    .Select(g => new {
                        Kod = g.Key,
                        Borc = g.Sum(x => x.DovizBorc),
                        Alacak = g.Sum(x => x.DovizAlacak)
                    })
                    .OrderBy(x => x.Kod)
                    .ToList();
            }
            <MudText Typo="Typo.body2">
                Kayıt: <b>@FiltreliKayit.Count</b> |
                Toplam Borç: <b>@topBorc.ToString("N2")</b> |
                Toplam Alacak: <b>@topAlacak.ToString("N2")</b> |
                Net: <b style="color:@netRenk">@netBak.ToString("N2") (@netDurum)</b>
            </MudText>
            @if (dovizGruplari.Count > 0)
            {
                <MudText Typo="Typo.body2" Style="color:#6a1b9a">
                    Döviz Toplamı:
                    @foreach (var d in dovizGruplari)
                    {
                        <span class="mr-3">
                            <b>@d.Kod</b> → Borç: <b>@d.Borc.ToString("N2")</b> / Alacak: <b>@d.Alacak.ToString("N2")</b>
                        </span>
                    }
                </MudText>
            }
        </MudItem>
    </MudGrid>
</MudPaper>

<MudTable Items="FiltreliKayit" Dense="true" Hover="true" Bordered="true" Striped="true"
          FixedHeader="true" Height="calc(100vh - 380px)"
          Breakpoint="Breakpoint.None"
          RowsPerPage="100"
          Class="mt-2">
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<CariHareket,object>(x => x.Tarih)">Tarih</MudTableSortLabel></MudTh>
        <MudTh>Ödeme Planı</MudTh>
        <MudTh>Fiş Türü</MudTh>
        <MudTh>Fiş No</MudTh>
        <MudTh>Açıklama</MudTh>
        <MudTh>Cari Kodu</MudTh>
        <MudTh>Cari Ünvanı</MudTh>
        <MudTh Style="text-align:right; background:#e8f5e9"><MudTableSortLabel SortBy="new Func<CariHareket,object>(x => x.Borc)">Borç</MudTableSortLabel></MudTh>
        <MudTh Style="text-align:right; background:#fff3e0"><MudTableSortLabel SortBy="new Func<CariHareket,object>(x => x.Alacak)">Alacak</MudTableSortLabel></MudTh>
        <MudTh Style="text-align:right; background:#e3f2fd">Bakiye</MudTh>
        <MudTh Style="text-align:center; background:#f3e5f5">Döviz</MudTh>
        <MudTh Style="text-align:right; background:#f3e5f5">Kur</MudTh>
        <MudTh Style="text-align:right; background:#e8f5e9">Döv. Borç</MudTh>
        <MudTh Style="text-align:right; background:#fff3e0">Döv. Alacak</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Tarih.ToString("dd.MM.yyyy")</MudTd>
        <MudTd>@context.OdemePlani</MudTd>
        <MudTd>@context.FisTuru</MudTd>
        <MudTd>@context.FisNo</MudTd>
        <MudTd>@context.Aciklama</MudTd>
        <MudTd>@context.CariKodu</MudTd>
        <MudTd>@context.CariUnvan</MudTd>
        <MudTd Style="text-align:right">@(context.Borc == 0 ? "" : context.Borc.ToString("N2"))</MudTd>
        <MudTd Style="text-align:right">@(context.Alacak == 0 ? "" : context.Alacak.ToString("N2"))</MudTd>
        <MudTd Style="@(context.Bakiye < 0 ? "text-align:right; color:#2e7d32; font-weight:600" : (context.Bakiye > 0 ? "text-align:right; color:#c62828; font-weight:600" : "text-align:right"))">@context.Bakiye.ToString("N2")</MudTd>
        <MudTd Style="text-align:center; font-weight:600; color:#6a1b9a">@context.DovizKodu</MudTd>
        <MudTd Style="text-align:right">@(context.TrCurr == 0 || context.DovizKur == 0 ? "" : context.DovizKur.ToString("N4"))</MudTd>
        <MudTd Style="text-align:right; color:#2e7d32">@(context.DovizBorc == 0 ? "" : context.DovizBorc.ToString("N2"))</MudTd>
        <MudTd Style="text-align:right; color:#c62828">@(context.DovizAlacak == 0 ? "" : context.DovizAlacak.ToString("N2"))</MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 50, 100, 250, 500, 1000 }" />
    </PagerContent>
    <NoRecordsContent>
        <MudText>Kayıt bulunamadı.</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Yükleniyor...</MudText>
    </LoadingContent>
</MudTable>

@code {
    private DateTime? _baslangic = new DateTime(DateTime.Today.Year, 1, 1);
    private DateTime? _bitis = DateTime.Today;
    private bool _yukleniyor = false;

    private string _aramaGenel = "";

    private List<CariHareket> _hareketler = new();
    private List<CariSecenek> _tumCariler = new();
    private CariSecenek? _seciliCari;

    private static readonly System.Globalization.CultureInfo _tr = new("tr-TR");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _tumCariler = await Logo.CariSecenekleriAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Cari listesi yüklenemedi: {ex.Message}", Severity.Error);
        }
    }

    private static bool Icerir(string? kaynak, string aranan)
    {
        if (string.IsNullOrEmpty(kaynak)) return false;
        return kaynak.ToUpper(_tr).Contains(aranan.ToUpper(_tr));
    }

    private Task<IEnumerable<CariSecenek>> CariAra(string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return Task.FromResult<IEnumerable<CariSecenek>>(_tumCariler.Take(50));

        var q = text.ToUpper(_tr);
        var sonuc = _tumCariler.Where(c =>
            (!string.IsNullOrEmpty(c.Kod) && c.Kod.ToUpper(_tr).Contains(q)) ||
            (!string.IsNullOrEmpty(c.Unvan) && c.Unvan.ToUpper(_tr).Contains(q)) ||
            (!string.IsNullOrEmpty(c.TcKimlikNo) && c.TcKimlikNo.Contains(q)) ||
            (!string.IsNullOrEmpty(c.VergiNo) && c.VergiNo.Contains(q))
        ).Take(100);

        return Task.FromResult<IEnumerable<CariSecenek>>(sonuc);
    }

    private void OnCariChanged(CariSecenek? cari)
    {
        _seciliCari = cari;
    }

    private List<CariHareket> FiltreliKayit =>
        string.IsNullOrWhiteSpace(_aramaGenel)
            ? _hareketler
            : _hareketler.Where(b =>
                Icerir(b.FisTuru, _aramaGenel) ||
                Icerir(b.FisNo, _aramaGenel) ||
                Icerir(b.Aciklama, _aramaGenel) ||
                Icerir(b.OdemePlani, _aramaGenel) ||
                Icerir(b.CariKodu, _aramaGenel) ||
                Icerir(b.CariUnvan, _aramaGenel)
              ).ToList();

    private async Task VeriYukle()
    {
        if (_baslangic == null || _bitis == null)
        {
            Snackbar.Add("Başlangıç ve bitiş tarihlerini seçin.", Severity.Warning);
            return;
        }
        if (_seciliCari == null || string.IsNullOrWhiteSpace(_seciliCari.Kod))
        {
            Snackbar.Add("Bir cari hesap seçin.", Severity.Warning);
            return;
        }

        _yukleniyor = true;
        try
        {
            var (liste, _, _, _) = await Logo.CariHareketListesiAsync(
                _baslangic.Value, _bitis.Value, _seciliCari.Kod, _seciliCari.Unvan);
            _hareketler = liste;
            Snackbar.Add($"{_hareketler.Count} hareket yüklendi.",
                _hareketler.Count > 0 ? Severity.Success : Severity.Warning);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Hata: {ex.Message}", Severity.Error);
        }
        finally
        {
            _yukleniyor = false;
        }
    }

    private async Task ExcelIndir()
    {
        if (_hareketler.Count == 0 || _baslangic == null || _bitis == null) return;
        try
        {
            var bytes = ExcelExportService.ExportCariHareket(
                FiltreliKayit, _baslangic.Value, _bitis.Value,
                _seciliCari?.Etiket ?? "");
            var kodKisim = _seciliCari?.Kod ?? "Tumu";
            var dosyaAdi = $"Cari_Hareket_{kodKisim}_{_baslangic:yyyyMMdd}_{_bitis:yyyyMMdd}.xlsx";
            using var stream = new MemoryStream(bytes);
            using var streamRef = new DotNetStreamReference(stream);
            await JS.InvokeVoidAsync("downloadFileFromStream", dosyaAdi, streamRef);
            Snackbar.Add("Excel dosyası indirildi.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Excel hatası: {ex.Message}", Severity.Error);
        }
    }
}
